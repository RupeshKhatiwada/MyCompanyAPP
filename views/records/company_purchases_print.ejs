<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= t('companyPurchasesTitle') %> | AQUA MSK</title>
  <link rel="stylesheet" href="/css/styles.css?v=<%= assetVersion %>" />
  <style>
    @media print { .print-hidden { display: none !important; } }
  </style>
</head>
<body class="bg-white text-slate-900">
  <div class="mx-auto max-w-6xl p-6">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div class="flex-1">
        <%- include('../partials/print-brand', { subtitle: t('companyPurchasesTitle') }) %>
        <p class="mt-2 text-sm text-slate-600">
          <%= t('from') %>: <%= from %> | <%= t('to') %>: <%= to %>
        </p>
        <% if (q) { %>
          <p class="text-xs text-slate-500"><%= t('search') %>: <%= q %></p>
        <% } %>
      </div>
      <div class="print-hidden flex flex-wrap gap-2">
        <button class="btn-outline" onclick="window.print()"><%= t('downloadPdf') %></button>
        <button class="btn-primary" onclick="window.print()"><%= t('print') %></button>
      </div>
    </div>
    <p class="mt-2 text-xs text-slate-500 print-hidden"><%= t('printOrSavePdfHint') %></p>

    <div class="mt-6 overflow-hidden rounded-2xl border border-slate-200">
      <table class="table-base">
        <thead class="table-head">
          <tr>
            <th class="px-4 py-3"><%= t('date') %></th>
            <th class="px-4 py-3"><%= t('itemName') %></th>
            <th class="px-4 py-3"><%= t('sellerName') %></th>
            <th class="px-4 py-3"><%= t('amount') %></th>
            <th class="px-4 py-3"><%= t('paidAmount') %></th>
            <th class="px-4 py-3"><%= t('remaining') %></th>
            <th class="px-4 py-3"><%= t('machineryName') %></th>
            <th class="px-4 py-3"><%= t('technicianName') %></th>
            <th class="px-4 py-3"><%= t('technicianPhone') %></th>
            <th class="px-4 py-3"><%= t('workDetails') %></th>
            <th class="px-4 py-3"><%= t('recordedBy') %></th>
          </tr>
        </thead>
        <tbody>
          <% if (!rows || rows.length === 0) { %>
            <tr>
              <td class="px-4 py-4 text-slate-500" colspan="10"><%= t('noPurchases') %></td>
            </tr>
          <% } %>
          <% (rows || []).forEach((row) => { %>
            <% const due = Math.max(0, Number(row.amount || 0) - Number(row.paid_amount || 0)); %>
            <tr class="table-row">
              <td class="px-4 py-3"><%= row.purchase_date %></td>
              <td class="px-4 py-3"><%= row.item_name %></td>
              <td class="px-4 py-3"><%= row.seller_name || '-' %></td>
              <td class="px-4 py-3"><%= row.amount %></td>
              <td class="px-4 py-3"><%= row.paid_amount || 0 %></td>
              <td class="px-4 py-3"><%= due %></td>
              <td class="px-4 py-3"><%= row.machinery_name || '-' %></td>
              <td class="px-4 py-3"><%= row.technician_name || '-' %></td>
              <td class="px-4 py-3"><%= row.technician_phone || '-' %></td>
              <td class="px-4 py-3"><%= row.work_details || '-' %></td>
              <td class="px-4 py-3"><%= row.recorded_by || '-' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="mt-6 grid gap-3 text-sm sm:grid-cols-5">
      <div class="card p-4">
        <p class="text-slate-500"><%= t('total') %></p>
        <p class="text-lg font-semibold"><%= totals.total %></p>
      </div>
      <div class="card p-4">
        <p class="text-slate-500"><%= t('totalPaid') %></p>
        <p class="text-lg font-semibold"><%= totals.paid || 0 %></p>
      </div>
      <div class="card p-4">
        <p class="text-slate-500"><%= t('totalDue') %></p>
        <p class="text-lg font-semibold"><%= totals.due || 0 %></p>
      </div>
      <div class="card p-4">
        <p class="text-slate-500"><%= t('machineryExpenses') %></p>
        <p class="text-lg font-semibold"><%= totals.machinery %></p>
      </div>
      <div class="card p-4">
        <p class="text-slate-500"><%= t('generalExpenses') %></p>
        <p class="text-lg font-semibold"><%= totals.general %></p>
      </div>
    </div>
  </div>
</body>
</html>
