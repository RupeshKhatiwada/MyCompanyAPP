<%- include('../partials/shell-start', { title }) %>
<section class="py-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-semibold"><%= record ? t('editCreditTitle') : t('addCreditTitle') %></h1>
      <p class="text-slate-600"><%= t('creditFormSubtitle') %></p>
    </div>
    <a class="btn-outline" href="/records/credits"><%= t('back') %></a>
  </div>

  <div class="mt-6 card p-6">
    <% if (error) { %>
      <div class="mb-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700"><%= error %></div>
    <% } %>
    <% const duplicateWarningValue = typeof duplicateWarning !== 'undefined' ? duplicateWarning : null; %>
    <%
      const safeFormValues = typeof formValues !== 'undefined' && formValues ? formValues : {};
      const isEdit = !!(record && record.id);
      const pickValue = (key, fallback = '') => {
        if (Object.prototype.hasOwnProperty.call(safeFormValues, key)) return safeFormValues[key];
        if (record && typeof record[key] !== 'undefined' && record[key] !== null) return record[key];
        return fallback;
      };
      const selectedVehicleRaw = pickValue('vehicle_id', typeof selectedVehicleId !== 'undefined' ? selectedVehicleId : '');
      const selectedVehicleValue = String(selectedVehicleRaw || '');
      const tripDateValue = pickValue('trip_date', typeof defaultTripDate !== 'undefined' ? defaultTripDate : '');
      const fallbackMethod = String(pickValue('payment_method', 'CASH') || 'CASH').toUpperCase();
      const fallbackPaidRaw = Number(pickValue('paid_amount', 0) || 0);
      const fallbackPaid = Number.isNaN(fallbackPaidRaw) || fallbackPaidRaw < 0 ? 0 : fallbackPaidRaw;
      const paidCashValue = pickValue('paid_cash_amount', fallbackMethod === 'CASH' ? fallbackPaid : 0);
      const paidBankValue = pickValue('paid_bank_amount', fallbackMethod === 'BANK' ? fallbackPaid : 0);
      const paidEWalletValue = pickValue('paid_ewallet_amount', fallbackMethod === 'E_WALLET' ? fallbackPaid : 0);
    %>
    <form method="post" action="<%= isEdit ? '/records/credits/' + record.id : '/records/credits' %>" class="space-y-4">
      <% if (duplicateWarningValue && duplicateWarningValue.type === 'credit') { %>
        <div class="rounded-lg border border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-900">
          <p class="font-semibold"><%= t('duplicateCreditWarningTitle') %></p>
          <p class="mt-1"><%= t('duplicateCreditWarningText') %></p>
          <div class="mt-3 overflow-x-auto">
            <table class="table-base text-xs">
              <thead class="table-head">
                <tr>
                  <th class="px-2 py-1"><%= t('receiptNo') %></th>
                  <th class="px-2 py-1"><%= t('date') %></th>
                  <th class="px-2 py-1"><%= t('vehicle') %></th>
                  <th class="px-2 py-1"><%= t('customerName') %></th>
                  <th class="px-2 py-1"><%= t('amount') %></th>
                </tr>
              </thead>
              <tbody>
                <% duplicateWarningValue.rows.forEach((row) => { %>
                  <tr class="table-row">
                    <td class="px-2 py-1"><%= row.receipt_no || (`#${row.id}`) %></td>
                    <td class="px-2 py-1"><%= row.credit_date %></td>
                    <td class="px-2 py-1"><%= `${row.owner_name} • ${row.vehicle_number}` %></td>
                    <td class="px-2 py-1"><%= row.customer_name %></td>
                    <td class="px-2 py-1"><%= row.amount %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <label class="mt-3 inline-flex items-center gap-2 text-sm">
            <input type="checkbox" name="allow_duplicate_entry" value="1" required />
            <span><%= t('confirmDuplicateEntry') %></span>
          </label>
        </div>
      <% } %>
      <div>
        <label class="label"><%= t('vehicle') %></label>
        <select class="input" name="vehicle_id" required>
          <option value=""><%= t('selectVehicle') %></option>
          <% vehicles.forEach((vehicle) => { %>
            <% const label = `${vehicle.owner_name} • ${vehicle.vehicle_number}`; %>
            <% const isSelected = Number(selectedVehicleValue || 0) === Number(vehicle.id); %>
            <option value="<%= vehicle.id %>" <%= isSelected ? 'selected' : '' %>><%= label %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="label"><%= t('tripDate') %></label>
        <input class="input" type="date" name="trip_date" value="<%= tripDateValue %>" />
        <p class="mt-1 text-xs text-slate-500"><%= t('tripDateCreditHint') %></p>
      </div>
      <div>
        <label class="label"><%= t('customerName') %></label>
        <input class="input" type="text" name="customer_name" list="customerList" value="<%= pickValue('customer_name', '') %>" required />
        <datalist id="customerList">
          <% (customers || []).forEach((name) => { %>
            <option value="<%= name %>"></option>
          <% }) %>
        </datalist>
      </div>
      <div>
        <label class="label"><%= t('date') %></label>
        <input class="input" type="date" name="credit_date" value="<%= pickValue('credit_date', defaultDate) %>" required />
      </div>
      <div class="grid gap-4 md:grid-cols-4">
        <div>
          <label class="label"><%= t('creditJars') %></label>
          <input id="creditJars" class="input" type="number" min="0" name="credit_jars" value="<%= pickValue('credit_jars', 0) %>" />
        </div>
        <div>
          <label class="label"><%= t('pricePerJar') %></label>
          <input id="jarPrice" class="input" type="number" min="0" step="0.01" name="jar_price" value="<%= pickValue('jar_price', 0) %>" />
        </div>
        <div>
          <label class="label"><%= t('creditBottleCases') %></label>
          <input id="creditBottles" class="input" type="number" min="0" name="credit_bottle_cases" value="<%= pickValue('credit_bottle_cases', 0) %>" />
        </div>
        <div>
          <label class="label"><%= t('pricePerBottleCase') %></label>
          <input id="bottlePrice" class="input" type="number" min="0" step="0.01" name="bottle_case_price" value="<%= pickValue('bottle_case_price', 0) %>" />
        </div>
      </div>
      <div class="grid gap-4 md:grid-cols-4">
        <div>
          <label class="label"><%= t('creditDispensers') %></label>
          <input id="creditDispensers" class="input" type="number" min="0" name="credit_dispensers" value="<%= pickValue('credit_dispensers', 0) %>" />
        </div>
        <div>
          <label class="label"><%= t('pricePerDispenser') %></label>
          <input id="dispenserPrice" class="input" type="number" min="0" step="0.01" name="dispenser_price" value="<%= pickValue('dispenser_price', 0) %>" />
        </div>
        <div>
          <label class="label"><%= t('creditJarContainers') %></label>
          <input id="creditJarContainers" class="input" type="number" min="0" name="credit_jar_containers" value="<%= pickValue('credit_jar_containers', 0) %>" />
        </div>
        <div>
          <label class="label"><%= t('jarContainerPrice') %></label>
          <input id="jarContainerPrice" class="input" type="number" min="0" step="0.01" name="jar_container_price" value="<%= pickValue('jar_container_price', 0) %>" />
        </div>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        <div>
          <label class="label"><%= t('amount') %></label>
          <input id="creditAmount" class="input bg-slate-50" type="number" step="0.01" name="amount" value="<%= pickValue('amount', 0) %>" readonly />
        </div>
        <div>
          <label class="label"><%= t('methodCash') %></label>
          <input id="paidCashAmount" class="input" type="number" step="0.01" min="0" name="paid_cash_amount" value="<%= Number(paidCashValue || 0) > 0 ? Number(paidCashValue || 0) : '' %>" />
        </div>
        <div>
          <label class="label"><%= t('methodBank') %></label>
          <input id="paidBankAmount" class="input" type="number" step="0.01" min="0" name="paid_bank_amount" value="<%= Number(paidBankValue || 0) > 0 ? Number(paidBankValue || 0) : '' %>" />
        </div>
      </div>
      <div>
        <div class="grid gap-4 md:grid-cols-3">
          <div>
            <label class="label"><%= t('methodEWallet') %></label>
            <input id="paidEWalletAmount" class="input" type="number" step="0.01" min="0" name="paid_ewallet_amount" value="<%= Number(paidEWalletValue || 0) > 0 ? Number(paidEWalletValue || 0) : '' %>" />
          </div>
          <div>
            <label class="label"><%= t('paidAmount') %></label>
            <input id="paidAmount" class="input bg-slate-50" type="number" step="0.01" min="0" name="paid_amount" value="<%= Number(fallbackPaid || 0) > 0 ? Number(fallbackPaid || 0) : '' %>" readonly />
          </div>
          <div>
            <label class="label"><%= t('remainingAmount') %></label>
            <input id="remainingAmount" class="input bg-slate-50" type="number" step="0.01" value="0" readonly />
          </div>
        </div>
        <input type="hidden" name="payment_method" value="CASH" />
      </div>
      <div class="flex items-center gap-2">
        <input id="markPaid" type="checkbox" name="paid" class="h-4 w-4" <%= Number(pickValue('amount', 0)) <= Number(pickValue('paid_amount', 0)) && Number(pickValue('amount', 0)) > 0 ? 'checked' : '' %> />
        <label class="label" for="markPaid"><%= t('markAsPaid') %></label>
      </div>
      <button class="btn-primary" type="submit"><%= t('save') %></button>
    </form>
  </div>
</section>
<script>
  (function () {
    var jarsInput = document.getElementById('creditJars');
    var jarPriceInput = document.getElementById('jarPrice');
    var bottlesInput = document.getElementById('creditBottles');
    var bottlePriceInput = document.getElementById('bottlePrice');
    var dispensersInput = document.getElementById('creditDispensers');
    var dispenserPriceInput = document.getElementById('dispenserPrice');
    var jarContainersInput = document.getElementById('creditJarContainers');
    var jarContainerPriceInput = document.getElementById('jarContainerPrice');
    var amountInput = document.getElementById('creditAmount');
    var paidInput = document.getElementById('paidAmount');
    var paidCashInput = document.getElementById('paidCashAmount');
    var paidBankInput = document.getElementById('paidBankAmount');
    var paidEWalletInput = document.getElementById('paidEWalletAmount');
    var remainingInput = document.getElementById('remainingAmount');
    var markPaid = document.getElementById('markPaid');
    if (!amountInput || !paidInput || !remainingInput) return;

    function toNumber(value) {
      var num = parseFloat(value);
      return Number.isFinite(num) ? num : 0;
    }
    function formatMoneyInput(value) {
      var safe = Math.round(Math.max(0, toNumber(value)) * 100) / 100;
      return safe > 0 ? String(safe) : '';
    }

    function syncAmounts() {
      var jars = Math.max(0, toNumber(jarsInput ? jarsInput.value : 0));
      var jarPrice = Math.max(0, toNumber(jarPriceInput ? jarPriceInput.value : 0));
      var bottles = Math.max(0, toNumber(bottlesInput ? bottlesInput.value : 0));
      var bottlePrice = Math.max(0, toNumber(bottlePriceInput ? bottlePriceInput.value : 0));
      var dispensers = Math.max(0, toNumber(dispensersInput ? dispensersInput.value : 0));
      var dispenserPrice = Math.max(0, toNumber(dispenserPriceInput ? dispenserPriceInput.value : 0));
      var jarContainers = Math.max(0, toNumber(jarContainersInput ? jarContainersInput.value : 0));
      var jarContainerPrice = Math.max(0, toNumber(jarContainerPriceInput ? jarContainerPriceInput.value : 0));
      var amount = (jars * jarPrice) + (bottles * bottlePrice) + (dispensers * dispenserPrice) + (jarContainers * jarContainerPrice);
      if (amount < 0) amount = 0;
      var paidCash = Math.max(0, toNumber(paidCashInput ? paidCashInput.value : 0));
      var paidBank = Math.max(0, toNumber(paidBankInput ? paidBankInput.value : 0));
      var paidEWallet = Math.max(0, toNumber(paidEWalletInput ? paidEWalletInput.value : 0));
      if (markPaid && markPaid.checked) {
        paidCash = amount;
        paidBank = 0;
        paidEWallet = 0;
      } else {
        var remainingCap = amount;
        var clamp = function (value) {
          var used = Math.min(value, remainingCap);
          remainingCap -= used;
          return used;
        };
        paidCash = clamp(paidCash);
        paidBank = clamp(paidBank);
        paidEWallet = clamp(paidEWallet);
      }
      var paid = paidCash + paidBank + paidEWallet;

      amountInput.value = amount.toFixed(2);
      if (paidCashInput) paidCashInput.value = formatMoneyInput(paidCash);
      if (paidBankInput) paidBankInput.value = formatMoneyInput(paidBank);
      if (paidEWalletInput) paidEWalletInput.value = formatMoneyInput(paidEWallet);
      paidInput.value = formatMoneyInput(paid);
      remainingInput.value = Math.max(0, amount - paid).toFixed(2);
    }

    ['input', 'change'].forEach(function (eventName) {
      [jarsInput, jarPriceInput, bottlesInput, bottlePriceInput, dispensersInput, dispenserPriceInput, jarContainersInput, jarContainerPriceInput, paidCashInput, paidBankInput, paidEWalletInput]
        .forEach(function (el) {
          if (el) el.addEventListener(eventName, syncAmounts);
        });
    });
    if (markPaid) {
      markPaid.addEventListener('change', function () {
        [paidCashInput, paidBankInput, paidEWalletInput].forEach(function (el) {
          if (el) el.readOnly = markPaid.checked;
        });
        syncAmounts();
      });
      [paidCashInput, paidBankInput, paidEWalletInput].forEach(function (el) {
        if (el) el.readOnly = markPaid.checked;
      });
    }
    syncAmounts();
  })();
</script>
<%- include('../partials/shell-end') %>
