<%- include('../partials/shell-start', { title }) %>
<section class="py-8">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-3xl font-semibold"><%= t('paymentHistoryTitle') %></h1>
      <p class="text-slate-600"><%= t('paymentHistorySubtitle') %></p>
    </div>
    <a class="btn-outline" href="/records/credits"><%= t('back') %></a>
  </div>

  <div class="mt-6 grid gap-4 lg:grid-cols-3">
    <div class="card p-6 lg:col-span-2">
      <h2 class="text-lg font-semibold"><%= t('creditDetails') %></h2>
      <div class="mt-4 grid gap-4 text-sm sm:grid-cols-2">
        <div>
          <p class="text-slate-500"><%= t('vehicleNumber') %></p>
          <p class="font-semibold"><%= `${record.owner_name} • ${record.vehicle_number}` %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('customerName') %></p>
          <p class="font-semibold"><%= record.customer_name %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('phone') %></p>
          <p class="font-semibold"><%= record.phone || '-' %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('date') %></p>
          <p class="font-semibold"><%= record.credit_date %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('linkedTrip') %></p>
          <p class="font-semibold"><%= record.trip_receipt_no || '-' %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('tripDate') %></p>
          <p class="font-semibold"><%= record.trip_date || '-' %></p>
        </div>
      </div>
    </div>
    <div class="card p-6">
      <h2 class="text-lg font-semibold"><%= t('addPayment') %></h2>
      <form class="mt-4 space-y-3" method="post" action="/records/credits/<%= record.id %>/pay">
        <div>
          <label class="label"><%= t('paymentAmount') %></label>
          <input class="input" type="number" step="0.01" min="0" max="<%= Math.max(0, record.amount - record.paid_amount) %>" name="payment_amount" required />
        </div>
        <button class="btn-primary w-full" type="submit"><%= t('addPayment') %></button>
      </form>
    </div>
  </div>

  <div class="mt-6 grid gap-3 text-sm sm:grid-cols-3">
    <div class="card p-4">
      <p class="text-slate-500"><%= t('totalAmount') %></p>
      <p class="text-lg font-semibold"><%= record.amount %></p>
    </div>
    <div class="card p-4">
      <p class="text-slate-500"><%= t('paidAmount') %></p>
      <p class="text-lg font-semibold"><%= paymentTotals.total_paid %></p>
    </div>
    <div class="card p-4">
      <p class="text-slate-500"><%= t('remainingAmount') %></p>
      <p class="text-lg font-semibold"><%= Math.max(0, record.amount - record.paid_amount) %></p>
    </div>
  </div>

  <div class="mt-6 card overflow-hidden">
    <div class="overflow-x-auto">
      <table class="table-base">
        <thead class="table-head">
          <tr>
            <th class="px-4 py-3"><%= t('dateTime') %></th>
            <th class="px-4 py-3"><%= t('amount') %></th>
            <th class="px-4 py-3"><%= t('note') %></th>
            <th class="px-4 py-3"><%= t('recordedBy') %></th>
          </tr>
        </thead>
        <tbody>
          <% if (payments.length === 0) { %>
            <tr>
              <td class="px-4 py-4 text-slate-500" colspan="4"><%= t('noPayments') %></td>
            </tr>
          <% } %>
          <% payments.forEach((payment) => { %>
            <tr class="table-row">
              <td class="px-4 py-3"><%= payment.paid_at %></td>
              <td class="px-4 py-3 <%= payment.amount >= 0 ? 'text-emerald-700' : 'text-red-600' %>"><%= payment.amount %></td>
              <td class="px-4 py-3"><%= payment.note || '-' %></td>
              <td class="px-4 py-3"><%= payment.full_name || '-' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>
<%- include('../partials/shell-end') %>
