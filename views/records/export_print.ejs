<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= t('exportsTitle') %> | AQUA MSK</title>
  <link rel="stylesheet" href="/css/styles.css?v=<%= assetVersion %>" />
  <style>
    @media print { .print-hidden { display: none !important; } }
  </style>
</head>
<body class="bg-white text-slate-900">
  <div class="mx-auto max-w-3xl p-6">
    <div class="flex items-center justify-between gap-4">
      <div class="flex-1">
        <%- include('../partials/print-brand', { subtitle: t('exportsTitle') }) %>
      </div>
      <button class="btn-primary print-hidden" onclick="window.print()"><%= t('print') %></button>
    </div>

    <div class="mt-6 card p-6">
      <% const paidAmount = Number(record.paid_amount || 0); %>
      <% const creditAmount = Number(record.credit_amount || 0); %>
      <% const totalExportAmount = Number(record.total_amount || 0); %>
      <div class="grid gap-4 sm:grid-cols-2 text-sm">
        <div>
          <p class="text-slate-500"><%= t('vehicleNumber') %></p>
          <p class="font-semibold"><%= record.vehicle_number %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('receiptNo') %></p>
          <p class="font-semibold"><%= record.receipt_no || (`#${record.id}`) %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('ownerName') %></p>
          <p class="font-semibold"><%= record.owner_name %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('phone') %></p>
          <p class="font-semibold"><%= record.phone || '-' %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('date') %></p>
          <p class="font-semibold"><%= record.export_date %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('route') %></p>
          <p class="font-semibold"><%= record.route || '-' %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('checkedByStaff') %></p>
          <p class="font-semibold"><%= record.checked_by_name || '-' %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('forceWash') %></p>
          <p class="font-semibold"><%= Number(record.force_wash_required || 0) === 1 ? t('yes') : t('no') %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('forceWashBy') %></p>
          <p class="font-semibold"><%= record.force_wash_staff_name || '-' %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('soldJarPrice') %></p>
          <p class="font-semibold"><%= record.sold_jar_price || 0 %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('pricePerJar') %></p>
          <p class="font-semibold"><%= record.jar_unit_price || 0 %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('pricePerBottleCase') %></p>
          <p class="font-semibold"><%= record.bottle_case_unit_price || 0 %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('pricePerDispenser') %></p>
          <p class="font-semibold"><%= record.dispenser_unit_price || 0 %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('expenseAmount') %></p>
          <p class="font-semibold"><%= record.expense_amount || 0 %></p>
        </div>
        <div>
          <p class="text-slate-500"><%= t('expenseNote') %></p>
          <p class="font-semibold"><%= record.expense_note || '-' %></p>
        </div>
      </div>

      <div class="mt-4 grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
          <p class="text-xs text-slate-500"><%= t('totalExportAmount') %></p>
          <p class="text-lg font-semibold"><%= totalExportAmount %></p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
          <p class="text-xs text-slate-500"><%= t('paidAmount') %></p>
          <p class="text-lg font-semibold text-emerald-700"><%= paidAmount %></p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
          <p class="text-xs text-slate-500"><%= t('creditAmount') %></p>
          <p class="text-lg font-semibold <%= creditAmount > 0 ? 'text-amber-700' : 'text-emerald-700' %>"><%= creditAmount %></p>
        </div>
      </div>

      <div class="mt-6 overflow-hidden rounded-2xl border border-slate-200">
        <table class="table-base">
          <thead class="table-head">
            <tr>
              <th class="px-4 py-3"><%= t('jars') %></th>
              <th class="px-4 py-3"><%= t('returnJars') %></th>
              <th class="px-4 py-3"><%= t('leakageJars') %></th>
              <th class="px-4 py-3"><%= t('netJars') %></th>
              <th class="px-4 py-3"><%= t('soldJars') %></th>
              <th class="px-4 py-3"><%= t('soldJarAmount') %></th>
              <th class="px-4 py-3"><%= t('bottleCases') %></th>
              <th class="px-4 py-3"><%= t('dispensers') %></th>
              <th class="px-4 py-3"><%= t('returnBottleCases') %></th>
              <th class="px-4 py-3"><%= t('netBottles') %></th>
              <th class="px-4 py-3"><%= t('totalExportAmount') %></th>
              <th class="px-4 py-3"><%= t('collectionAmount') %></th>
              <th class="px-4 py-3"><%= t('expenseAmount') %></th>
              <th class="px-4 py-3"><%= t('netCollectionAmount') %></th>
              <th class="px-4 py-3"><%= t('paidAmount') %></th>
              <th class="px-4 py-3"><%= t('creditAmount') %></th>
            </tr>
          </thead>
          <tbody>
            <% const netJars = Math.max(0, (record.jar_count || 0) - (record.return_jar_count || 0) - (record.leakage_jar_count || 0)); %>
            <% const netBottles = Math.max(0, (record.bottle_case_count || 0) - (record.return_bottle_case_count || 0)); %>
            <% const collectionAmount = Number(record.collection_amount || 0); %>
            <% const expenseAmount = Number(record.expense_amount || 0); %>
            <% const netCollectionAmount = Math.max(0, collectionAmount - expenseAmount); %>
            <tr class="table-row">
              <td class="px-4 py-3"><%= record.jar_count %></td>
              <td class="px-4 py-3"><%= record.return_jar_count %></td>
              <td class="px-4 py-3"><%= record.leakage_jar_count %></td>
              <td class="px-4 py-3"><%= netJars %></td>
              <td class="px-4 py-3"><%= record.sold_jar_count || 0 %></td>
              <td class="px-4 py-3"><%= record.sold_jar_amount || 0 %></td>
              <td class="px-4 py-3"><%= record.bottle_case_count %></td>
              <td class="px-4 py-3"><%= record.dispenser_count || 0 %></td>
              <td class="px-4 py-3"><%= record.return_bottle_case_count %></td>
              <td class="px-4 py-3"><%= netBottles %></td>
              <td class="px-4 py-3"><%= totalExportAmount %></td>
              <td class="px-4 py-3"><%= collectionAmount %></td>
              <td class="px-4 py-3"><%= expenseAmount %></td>
              <td class="px-4 py-3"><%= netCollectionAmount %></td>
              <td class="px-4 py-3"><%= paidAmount %></td>
              <td class="px-4 py-3"><%= creditAmount %></td>
            </tr>
          </tbody>
        </table>
      </div>

      <% if (record.note) { %>
        <p class="mt-4 text-sm text-slate-600"><strong><%= t('note') %>:</strong> <%= record.note %></p>
      <% } %>
    </div>
  </div>
</body>
</html>
