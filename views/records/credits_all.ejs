<%- include('../partials/shell-start', { title }) %>
<section class="py-8">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-3xl font-semibold"><%= t('allCreditsTitle') %></h1>
      <p class="text-slate-600"><%= t('allCreditsSubtitle') %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a class="btn-outline" href="/records/credits/all/export?from=<%= from %>&to=<%= to %>&q=<%= encodeURIComponent(q || '') %>"><%= t('exportCsv') %></a>
      <a class="btn-outline" href="/records/credits/all/print?from=<%= from %>&to=<%= to %>&q=<%= encodeURIComponent(q || '') %>" target="_blank"><%= t('print') %></a>
      <a class="btn-outline" href="/records/credits"><%= t('credits') %></a>
    </div>
  </div>

  <form class="mt-4 flex flex-wrap items-end gap-3" method="get" action="/records/credits/all">
    <div>
      <label class="label"><%= t('from') %></label>
      <input class="input" type="date" name="from" value="<%= from %>" />
    </div>
    <div>
      <label class="label"><%= t('to') %></label>
      <input class="input" type="date" name="to" value="<%= to %>" />
    </div>
    <div class="min-w-[220px]">
      <label class="label"><%= t('search') %></label>
      <input class="input" type="text" name="q" value="<%= q || '' %>" placeholder="<%= t('searchPlaceholder') %>" />
    </div>
    <button class="btn-outline" type="submit"><%= t('filter') %></button>
  </form>

  <div class="mt-6 card overflow-hidden">
    <div class="overflow-x-auto">
      <table class="table-base">
        <thead class="table-head">
          <tr>
            <th class="px-4 py-3"><%= t('date') %></th>
            <th class="px-4 py-3"><%= t('source') %></th>
            <th class="px-4 py-3"><%= t('vehicle') %></th>
            <th class="px-4 py-3"><%= t('customerName') %></th>
            <th class="px-4 py-3"><%= t('amount') %></th>
            <th class="px-4 py-3"><%= t('paidAmount') %></th>
            <th class="px-4 py-3"><%= t('remainingAmount') %></th>
          </tr>
        </thead>
        <tbody>
          <% if (rows.length === 0) { %>
            <tr>
              <td class="px-4 py-4 text-slate-500" colspan="7"><%= t('noCredits') %></td>
            </tr>
          <% } %>
          <% rows.forEach((row) => { %>
            <% const isExport = row.source === 'export'; %>
            <tr class="table-row">
              <td class="px-4 py-3"><%= row.credit_date %></td>
              <td class="px-4 py-3">
                <span class="badge <%= isExport ? 'bg-sky-100 text-sky-700' : 'bg-amber-100 text-amber-700' %>">
                  <%= isExport ? t('sourceExport') : t('sourceCustomer') %>
                </span>
              </td>
              <td class="px-4 py-3"><%= `${row.owner_name} • ${row.vehicle_number}` %></td>
              <td class="px-4 py-3"><%= row.customer_name || '-' %></td>
              <td class="px-4 py-3"><%= row.credit_amount %></td>
              <td class="px-4 py-3"><%= row.paid_amount %></td>
              <td class="px-4 py-3"><%= row.remaining_amount %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mt-4 grid gap-3 text-sm sm:grid-cols-2 lg:grid-cols-4">
    <div class="card p-4">
      <p class="text-slate-500"><%= t('totalAmount') %></p>
      <p class="text-lg font-semibold"><%= totals.total %></p>
    </div>
    <div class="card p-4">
      <p class="text-slate-500"><%= t('totalRemaining') %></p>
      <p class="text-lg font-semibold"><%= totals.remaining %></p>
    </div>
    <div class="card p-4">
      <p class="text-slate-500"><%= t('exportCredits') %></p>
      <p class="text-lg font-semibold"><%= totals.exportTotal %></p>
    </div>
    <div class="card p-4">
      <p class="text-slate-500"><%= t('customerCredits') %></p>
      <p class="text-lg font-semibold"><%= totals.customerTotal %></p>
    </div>
  </div>
</section>
<%- include('../partials/shell-end') %>
