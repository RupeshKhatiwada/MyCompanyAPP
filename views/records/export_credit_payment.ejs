<%- include('../partials/shell-start', { title }) %>
<section class="py-8">
  <div class="mx-auto max-w-2xl card p-6">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h1 class="text-2xl font-semibold"><%= t('payExportCreditTitle') %></h1>
        <p class="text-slate-600"><%= t('payExportCreditSubtitle') %></p>
      </div>
      <a class="btn-outline" href="/records/exports?from=<%= record.export_date %>&to=<%= record.export_date %>"><%= t('back') %></a>
    </div>

    <% if (error) { %>
      <div class="mt-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700"><%= error %></div>
    <% } %>

    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      <div class="card p-4">
        <p class="text-slate-500"><%= t('date') %></p>
        <p class="font-semibold"><%= record.export_date %></p>
      </div>
      <div class="card p-4">
        <p class="text-slate-500"><%= t('receiptNo') %></p>
        <p class="font-semibold"><%= record.receipt_no || (`#${record.id}`) %></p>
      </div>
      <div class="card p-4 sm:col-span-2">
        <p class="text-slate-500"><%= t('vehicle') %></p>
        <p class="font-semibold"><%= `${record.owner_name} • ${record.vehicle_number}` %></p>
      </div>
      <div class="card p-4">
        <p class="text-slate-500"><%= t('totalExportAmount') %></p>
        <p class="font-semibold"><%= Number(record.total_amount || 0).toFixed(2) %></p>
      </div>
      <div class="card p-4">
        <p class="text-slate-500"><%= t('paidAmount') %></p>
        <p class="font-semibold"><%= Number(record.paid_amount || 0).toFixed(2) %></p>
      </div>
      <div class="card p-4 sm:col-span-2">
        <p class="text-slate-500"><%= t('remainingAmount') %></p>
        <p class="text-lg font-semibold"><%= Number(remaining || 0).toFixed(2) %></p>
      </div>
    </div>

    <form class="mt-6 space-y-4" method="post" action="/records/exports/<%= record.id %>/pay-credit">
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <div>
          <label class="label"><%= t('methodCash') %></label>
          <input class="input" type="number" min="0" step="0.01" max="<%= Number(remaining || 0).toFixed(2) %>" name="cash_amount" data-cash />
        </div>
        <div>
          <label class="label"><%= t('methodBank') %></label>
          <input class="input" type="number" min="0" step="0.01" max="<%= Number(remaining || 0).toFixed(2) %>" name="bank_amount" data-bank />
        </div>
        <div>
          <label class="label"><%= t('methodEWallet') %></label>
          <input class="input" type="number" min="0" step="0.01" max="<%= Number(remaining || 0).toFixed(2) %>" name="ewallet_amount" data-ewallet />
        </div>
        <div>
          <label class="label"><%= t('paymentAmount') %></label>
          <input class="input bg-slate-50" type="number" min="0" step="0.01" name="payment_amount" data-total readonly />
        </div>
      </div>
      <input type="hidden" name="payment_method" value="CASH" />
      <button class="btn-primary" type="submit"><%= t('addPayment') %></button>
    </form>
  </div>
</section>
<script>
  (() => {
    const remaining = Number("<%= Number(remaining || 0).toFixed(2) %>");
    const cashInput = document.querySelector("[data-cash]");
    const bankInput = document.querySelector("[data-bank]");
    const ewalletInput = document.querySelector("[data-ewallet]");
    const totalInput = document.querySelector("[data-total]");
    if (!cashInput || !bankInput || !ewalletInput || !totalInput) return;

    const toSafe = (value) => {
      const num = Number(value || 0);
      if (Number.isNaN(num) || num < 0) return 0;
      return num;
    };
    const formatMoneyInput = (value) => {
      const safe = Math.round(toSafe(value) * 100) / 100;
      return safe > 0 ? String(safe) : "";
    };

    const recalc = () => {
      let cash = toSafe(cashInput.value);
      let bank = toSafe(bankInput.value);
      let ewallet = toSafe(ewalletInput.value);
      let remainingCap = Math.max(remaining, 0);
      const clamp = (value) => {
        const used = Math.min(value, remainingCap);
        remainingCap -= used;
        return used;
      };
      cash = clamp(cash);
      bank = clamp(bank);
      ewallet = clamp(ewallet);
      cashInput.value = formatMoneyInput(cash);
      bankInput.value = formatMoneyInput(bank);
      ewalletInput.value = formatMoneyInput(ewallet);
      totalInput.value = formatMoneyInput(cash + bank + ewallet);
    };

    [cashInput, bankInput, ewalletInput].forEach((el) => {
      el.addEventListener("input", recalc);
    });
    recalc();
  })();
</script>
<%- include('../partials/shell-end') %>
