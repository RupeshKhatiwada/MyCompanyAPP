<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= t('creditsTitle') %> | AQUA MSK</title>
  <link rel="stylesheet" href="/css/styles.css?v=<%= assetVersion %>" />
  <style>
    :root { color-scheme: light; }
    .bill-wrap {
      max-width: 430px;
      margin: 0 auto;
      padding: 16px;
    }
    .bill-card {
      border: 1px solid #e2e8f0;
      border-radius: 16px;
      background: #fff;
      padding: 16px;
    }
    .meta-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px 12px;
      margin-top: 12px;
    }
    .meta-label {
      font-size: 11px;
      color: #64748b;
    }
    .meta-value {
      font-size: 13px;
      font-weight: 600;
      color: #0f172a;
      word-break: break-word;
    }
    .divider {
      border-top: 1px dashed #cbd5e1;
      margin: 12px 0;
    }
    .line-item {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto auto;
      gap: 8px;
      align-items: start;
      padding: 8px 0;
      border-bottom: 1px dashed #e2e8f0;
    }
    .line-item:last-child {
      border-bottom: none;
    }
    .line-item-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto auto;
      gap: 8px;
      padding: 6px 0;
      font-size: 11px;
      color: #64748b;
      border-bottom: 1px solid #e2e8f0;
    }
    .line-item-head span {
      text-align: right;
      white-space: nowrap;
    }
    .line-item-head span:first-child {
      text-align: left;
    }
    .line-item-name {
      font-size: 13px;
      font-weight: 600;
      color: #0f172a;
      line-height: 1.25;
    }
    .line-item-sub {
      margin-top: 2px;
      font-size: 11px;
      color: #64748b;
      line-height: 1.3;
    }
    .line-item-value {
      font-size: 13px;
      color: #0f172a;
      text-align: right;
      white-space: nowrap;
    }
    .totals .row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      font-size: 13px;
      color: #0f172a;
      padding: 4px 0;
    }
    .totals .final {
      border-top: 1px solid #cbd5e1;
      margin-top: 8px;
      padding-top: 8px;
      font-size: 15px;
      font-weight: 700;
    }
    .print-actions {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 10px;
    }
    @page {
      size: 80mm auto;
      margin: 8mm;
    }
    @media print {
      body {
        background: #fff !important;
      }
      .print-hidden {
        display: none !important;
      }
      .bill-wrap {
        max-width: none;
        margin: 0;
        padding: 0;
      }
      .bill-card {
        border: none;
        border-radius: 0;
        padding: 0;
      }
    }
  </style>
</head>
<body class="bg-slate-100 text-slate-900">
  <% const toNumber = (value) => Number(value || 0); %>
  <% const creditJars = toNumber(record.credit_jars); %>
  <% const creditBottleCases = toNumber(record.credit_bottle_cases); %>
  <% const creditDispensers = toNumber(record.credit_dispensers); %>
  <% const creditJarContainers = toNumber(record.credit_jar_containers); %>
  <% const jarPrice = toNumber(record.jar_price); %>
  <% const bottleCasePrice = toNumber(record.bottle_case_price); %>
  <% const dispenserPrice = toNumber(record.dispenser_price); %>
  <% const jarContainerPrice = toNumber(record.jar_container_price); %>
  <% const amount = toNumber(record.amount); %>
  <% const paidAmount = toNumber(record.paid_amount); %>
  <% const remainingAmount = Math.max(0, amount - paidAmount); %>
  <% const isPaid = paidAmount >= amount && amount > 0; %>
  <% const isPartial = !isPaid && paidAmount > 0; %>
  <% const statusLabel = isPaid ? t('paid') : (isPartial ? t('statusPartial') : t('unpaid')); %>
  <% const itemLines = []; %>
  <% if (creditJars > 0) { %>
    <% itemLines.push({ label: t('creditJars'), qty: creditJars, unitPrice: jarPrice, amount: creditJars * jarPrice }); %>
  <% } %>
  <% if (creditBottleCases > 0) { %>
    <% itemLines.push({ label: t('creditBottleCases'), qty: creditBottleCases, unitPrice: bottleCasePrice, amount: creditBottleCases * bottleCasePrice }); %>
  <% } %>
  <% if (creditDispensers > 0) { %>
    <% itemLines.push({ label: t('creditDispensers'), qty: creditDispensers, unitPrice: dispenserPrice, amount: creditDispensers * dispenserPrice }); %>
  <% } %>
  <% if (creditJarContainers > 0) { %>
    <% itemLines.push({ label: t('creditJarContainers'), qty: creditJarContainers, unitPrice: jarContainerPrice, amount: creditJarContainers * jarContainerPrice }); %>
  <% } %>

  <div class="bill-wrap">
    <div class="print-actions print-hidden">
      <button class="btn-primary" onclick="window.print()"><%= t('print') %></button>
    </div>

    <div class="bill-card">
      <%- include('../partials/print-brand', { subtitle: t('creditsTitle') }) %>

      <div class="meta-grid">
        <div>
          <p class="meta-label"><%= t('receiptNo') %></p>
          <p class="meta-value"><%= record.receipt_no || (`#${record.id}`) %></p>
        </div>
        <div>
          <p class="meta-label"><%= t('creditDate') %></p>
          <p class="meta-value"><%= typeof formatDateDual === 'function' ? formatDateDual(record.credit_date) : record.credit_date %></p>
        </div>
        <div>
          <p class="meta-label"><%= t('vehicleNumber') %></p>
          <p class="meta-value"><%= `${record.owner_name} • ${record.vehicle_number}` %></p>
        </div>
        <div>
          <p class="meta-label"><%= t('customerName') %></p>
          <p class="meta-value"><%= record.customer_name %></p>
        </div>
        <% if (record.phone) { %>
          <div>
            <p class="meta-label"><%= t('phone') %></p>
            <p class="meta-value"><%= record.phone %></p>
          </div>
        <% } %>
        <% if (record.trip_receipt_no) { %>
          <div>
            <p class="meta-label"><%= t('linkedTrip') %></p>
            <p class="meta-value"><%= record.trip_receipt_no %></p>
          </div>
        <% } %>
        <% if (record.trip_date) { %>
          <div>
            <p class="meta-label"><%= t('tripDate') %></p>
            <p class="meta-value"><%= typeof formatDateDual === 'function' ? formatDateDual(record.trip_date) : record.trip_date %></p>
          </div>
        <% } %>
      </div>

      <div class="divider"></div>

      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500"><%= t('allItems') %></p>
      <% if (itemLines.length === 0) { %>
        <p class="mt-2 text-xs text-slate-500"><%= t('noData') %></p>
      <% } else { %>
        <div class="mt-1">
          <div class="line-item-head">
            <span><%= t('allItems') %></span>
            <span><%= t('quantity') %></span>
            <span><%= t('amount') %></span>
          </div>
          <% itemLines.forEach((item) => { %>
            <div class="line-item">
              <div>
                <p class="line-item-name"><%= item.label %></p>
                <% if (item.unitPrice > 0) { %>
                  <p class="line-item-sub"><%= t('unit') %>: <%= item.unitPrice %></p>
                <% } %>
              </div>
              <p class="line-item-value"><%= item.qty %></p>
              <p class="line-item-value"><%= item.amount > 0 ? item.amount : '-' %></p>
            </div>
          <% }) %>
        </div>
      <% } %>

      <div class="divider"></div>

      <div class="totals">
        <div class="row">
          <span><%= t('amount') %></span>
          <strong><%= amount %></strong>
        </div>
        <div class="row">
          <span><%= t('paidAmount') %></span>
          <strong><%= paidAmount %></strong>
        </div>
        <div class="row">
          <span><%= t('remainingAmount') %></span>
          <strong><%= remainingAmount %></strong>
        </div>
        <div class="row final">
          <span><%= t('status') %></span>
          <strong><%= statusLabel %></strong>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
