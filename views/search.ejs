<%- include('partials/shell-start', { title }) %>
<% const isAdmin = currentUser && (currentUser.role === 'ADMIN' || currentUser.role === 'SUPER_ADMIN'); %>
<section class="py-8">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-3xl font-semibold"><%= t('searchTitle') %></h1>
      <p class="text-slate-600"><%= t('searchGlobalHelp') %></p>
    </div>
  </div>

  <form class="mt-4 flex flex-wrap items-end gap-3" method="get" action="/search">
    <div class="min-w-[240px]">
      <label class="label"><%= t('search') %></label>
      <input class="input" type="text" name="q" value="<%= q || '' %>" placeholder="<%= t('searchGlobal') %>" />
    </div>
    <button class="btn-outline" type="submit"><%= t('search') %></button>
  </form>

  <div class="mt-6 grid gap-4 lg:grid-cols-2">
    <div class="card p-6">
      <h2 class="text-lg font-semibold"><%= t('vehicles') %></h2>
      <div class="mt-3 space-y-2 text-sm">
        <% if (!vehicles || vehicles.length === 0) { %>
          <p class="text-slate-500"><%= t('noVehiclesFound') %></p>
        <% } %>
        <% vehicles.forEach((v) => { %>
          <div class="flex items-center justify-between gap-3 border-b border-slate-100 pb-2">
            <div>
              <p class="font-semibold"><%= v.vehicle_number %></p>
              <p class="text-xs text-slate-500"><%= v.owner_name %> <%= v.phone ? `• ${v.phone}` : '' %></p>
            </div>
            <div class="flex flex-wrap gap-2">
              <a class="btn-outline" href="/records/exports?from=<%= encodeURIComponent(today) %>&to=<%= encodeURIComponent(today) %>&q=<%= encodeURIComponent(v.vehicle_number) %>"><%= t('exports') %></a>
              <a class="btn-outline" href="/records/credits?from=<%= encodeURIComponent(today) %>&to=<%= encodeURIComponent(today) %>&q=<%= encodeURIComponent(v.vehicle_number) %>"><%= t('credits') %></a>
              <% if (isAdmin) { %>
                <a class="btn-outline" href="/admin/vehicles"><%= t('manage') %></a>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="card p-6">
      <h2 class="text-lg font-semibold"><%= t('customers') %></h2>
      <div class="mt-3 space-y-2 text-sm">
        <% if (!customers || customers.length === 0) { %>
          <p class="text-slate-500"><%= t('noCustomersFound') %></p>
        <% } %>
        <% customers.forEach((name) => { %>
          <div class="flex items-center justify-between gap-3 border-b border-slate-100 pb-2">
            <div>
              <p class="font-semibold"><%= name %></p>
            </div>
            <div class="flex flex-wrap gap-2">
              <a class="btn-outline" href="/records/credits?from=<%= encodeURIComponent(today) %>&to=<%= encodeURIComponent(today) %>&q=<%= encodeURIComponent(name) %>"><%= t('credits') %></a>
              <% if (isAdmin) { %>
                <a class="btn-outline" href="/admin/reports/customer-invoice?customer=<%= encodeURIComponent(name) %>"><%= t('customerInvoiceTitle') %></a>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</section>
<%- include('partials/shell-end') %>
