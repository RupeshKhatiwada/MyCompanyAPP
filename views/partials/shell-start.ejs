<!DOCTYPE html>
<html lang="<%= lang %>" data-calendar-mode="<%= calendarMode || 'AD' %>" data-calendar-available="<%= canConvertBs ? '1' : '0' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | AQUA MSK</title>
  <link rel="stylesheet" href="/css/styles.css?v=<%= assetVersion %>" />
  <script src="/js/calendar-ui.js?v=<%= assetVersion %>" defer></script>
  <style>
    :root[data-font-size="sm"] { font-size: 14px; }
    :root[data-font-size="md"] { font-size: 16px; }
    :root[data-font-size="lg"] { font-size: 18px; }
    :root[data-font-size="xl"] { font-size: 20px; }
    .print-only { display: none; }
    .action-menu { position: relative; display: inline-block; }
    .action-menu[open] { z-index: 10000; }
    .action-menu > summary { list-style: none; }
    .action-menu > summary::-webkit-details-marker { display: none; }
    .action-menu-panel {
      position: absolute;
      right: 0;
      top: calc(100% + 6px);
      min-width: 180px;
      max-width: min(220px, calc(100vw - 1.5rem));
      max-height: min(320px, calc(100vh - 1rem));
      border: 1px solid rgba(226, 232, 240, 0.9);
      background: #fff;
      border-radius: 0.75rem;
      box-shadow: 0 12px 24px rgba(15, 23, 42, 0.14);
      padding: 6px;
      overflow-y: auto;
      overscroll-behavior: contain;
      z-index: 40;
    }
    .action-menu.action-menu-up .action-menu-panel {
      top: auto;
      bottom: calc(100% + 6px);
    }
    .action-menu-item {
      display: block;
      width: 100%;
      text-align: left;
      padding: 8px 10px;
      font-size: 0.85rem;
      border-radius: 0.5rem;
      color: #0f172a;
    }
    .action-menu-item:hover {
      background: #f1f5f9;
    }
    .action-menu-danger {
      color: #b91c1c;
    }
    .action-menu-danger:hover {
      background: #fee2e2;
    }
    .table-action-sticky {
      position: sticky;
      right: 0;
      z-index: 2;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: -6px 0 8px -8px rgba(15, 23, 42, 0.25);
      overflow: visible;
    }
    .table-head .table-action-sticky {
      background: rgba(241, 245, 249, 0.98);
      z-index: 3;
    }
    @media print {
      .print-only { display: block !important; }
      .print-hidden { display: none !important; }
    }
  </style>
  <script>
    (function () {
      try {
        var size = localStorage.getItem('fontSize') || 'md';
        document.documentElement.dataset.fontSize = size;
      } catch (e) {}
    })();
    (function () {
      var selector = "details.action-menu";
      function isForcedUp(menu) {
        return menu && menu.dataset && menu.dataset.forceUp === "1";
      }

      function getPanel(menu) {
        if (!(menu instanceof HTMLElement)) return null;
        var panel = menu.querySelector(".action-menu-panel");
        return panel instanceof HTMLElement ? panel : null;
      }

      function resetPanelPosition(menu) {
        var panel = getPanel(menu);
        if (!panel) return;
        panel.style.left = "";
        panel.style.top = "";
        panel.style.right = "";
        panel.style.bottom = "";
        panel.style.maxHeight = "";
        panel.style.visibility = "";
        panel.style.display = "";
      }

      function closeAll(except) {
        var menus = document.querySelectorAll(selector + "[open]");
        for (var i = 0; i < menus.length; i += 1) {
          if (!except || menus[i] !== except) {
            resetPanelPosition(menus[i]);
            menus[i].classList.remove("action-menu-up");
            menus[i].open = false;
          }
        }
      }

      function placeMenu(menu) {
        if (!(menu instanceof HTMLElement)) return;
        var panel = getPanel(menu);
        if (!(panel instanceof HTMLElement)) return;
        var anchor = menu.querySelector("summary");
        var anchorRect = (anchor instanceof HTMLElement ? anchor : menu).getBoundingClientRect();
        var viewportMargin = 8;

        panel.style.left = "";
        panel.style.right = "";
        panel.style.maxHeight = "";
        panel.style.visibility = "hidden";
        panel.style.display = "block";

        var panelRect = panel.getBoundingClientRect();
        var panelHeight = Math.max(panelRect.height || 120, 120);
        panel.style.display = "";
        panel.style.visibility = "";

        var spaceBelow = Math.max(0, window.innerHeight - anchorRect.bottom - viewportMargin);
        var spaceAbove = Math.max(0, anchorRect.top - viewportMargin);
        var openUp = isForcedUp(menu) || (panelHeight > spaceBelow && spaceAbove > spaceBelow);

        if (openUp) menu.classList.add("action-menu-up");
        else menu.classList.remove("action-menu-up");

        var availableSpace = openUp ? spaceAbove : spaceBelow;
        panel.style.maxHeight = Math.max(140, Math.floor(availableSpace)) + "px";

        var viewportRect = panel.getBoundingClientRect();
        if (viewportRect.left < viewportMargin) {
          panel.style.left = "0";
          panel.style.right = "auto";
          viewportRect = panel.getBoundingClientRect();
        }
        if (viewportRect.right > window.innerWidth - viewportMargin) {
          panel.style.left = "auto";
          panel.style.right = "0";
        }
      }

      document.addEventListener("toggle", function (event) {
        var target = event && event.target;
        if (!(target instanceof HTMLElement)) return;
        if (!target.matches(selector)) return;
        if (target.open) {
          closeAll(target);
          placeMenu(target);
        } else {
          resetPanelPosition(target);
          target.classList.remove("action-menu-up");
        }
      }, true);

      document.addEventListener("click", function (event) {
        var target = event && event.target;
        if (!(target instanceof Element)) return;
        if (!target.closest(selector)) closeAll();
      });

      document.addEventListener("keydown", function (event) {
        if (event.key === "Escape") closeAll();
      });

      document.addEventListener("scroll", function () {
        var openMenus = document.querySelectorAll(selector + "[open]");
        for (var i = 0; i < openMenus.length; i += 1) {
          placeMenu(openMenus[i]);
        }
      }, true);

      window.addEventListener("resize", function () {
        var openMenus = document.querySelectorAll(selector + "[open]");
        for (var i = 0; i < openMenus.length; i += 1) {
          placeMenu(openMenus[i]);
        }
      });
    })();
  </script>
</head>
<body class="text-slate-900">
  <div class="min-h-screen">
    <%- include('nav') %>
    <main class="mx-auto w-full max-w-6xl px-4 pb-16 pt-6">
