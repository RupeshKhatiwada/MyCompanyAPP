<% const printedAt = new Date().toLocaleString(); %>
<div class="flex items-center justify-between gap-3">
  <div class="flex items-center gap-3">
    <div class="h-10 w-10 rounded-xl bg-white ring-1 ring-slate-200 flex items-center justify-center overflow-hidden">
      <% if (logoPath) { %>
        <img src="<%= logoPath %>" alt="logo" class="h-10 w-10 object-contain" />
      <% } else { %>
        <span class="text-sm font-bold text-aqua-700">A</span>
      <% } %>
    </div>
    <div>
      <% if (brandWordmarkPath) { %>
        <img src="<%= brandWordmarkPath %>" alt="AQUA MSK" class="h-6 w-auto object-contain" />
      <% } else { %>
        <p class="text-lg font-semibold">AQUA MSK</p>
      <% } %>
      <p class="text-xs text-slate-500"><%= subtitle %></p>
    </div>
  </div>
  <div class="text-right text-xs text-slate-500">
    <p><%= t('printedOn') %>: <%= printedAt %></p>
  </div>
</div>
