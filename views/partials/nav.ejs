              <a class="btn-outline" href="/admin/backup"><%= t('backup') %></a>
            </div>
          </div>
          <div>
            <p class="pill"><%= t('menuPeopleAccess') %></p>
            <div class="mt-2 grid gap-2 sm:grid-cols-2">
