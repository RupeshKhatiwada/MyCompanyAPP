  <script>
    (function () {
      var toggle = document.getElementById('menuToggle');
      var panel = document.getElementById('menuPanel');
      if (!toggle || !panel) return;
      function openPanel() {
        panel.hidden = false;
        panel.classList.remove('hidden');
        toggle.setAttribute('aria-expanded', 'true');
      }
      function closePanel() {
        panel.classList.add('hidden');
        panel.hidden = true;
        toggle.setAttribute('aria-expanded', 'false');
      }
      toggle.addEventListener('click', function () {
        if (panel.hidden || panel.classList.contains('hidden')) {
          openPanel();
        } else {
          closePanel();
        }
      });
      panel.addEventListener('click', function (event) {
        if (event.target && event.target.dataset && event.target.dataset.close !== undefined) {
          closePanel();
        }
      });
      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') closePanel();
      });
    })();
  </script>
<% } %>
<script>
  (function () {
    function initFontToggles() {
      var buttons = document.querySelectorAll('.font-size-toggle');
      if (!buttons.length) return;
      function setActive(size) {
        buttons.forEach(function (btn) {
          if (btn.dataset.fontSize === size) {
            btn.classList.add('bg-slate-100');
          } else {
            btn.classList.remove('bg-slate-100');
          }
        });
      }
      var current = document.documentElement.dataset.fontSize || 'md';
      setActive(current);
      buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var size = btn.dataset.fontSize || 'md';
          document.documentElement.dataset.fontSize = size;
          try { localStorage.setItem('fontSize', size); } catch (e) {}
          setActive(size);
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFontToggles);
    } else {
      initFontToggles();
    }
  })();
</script>
