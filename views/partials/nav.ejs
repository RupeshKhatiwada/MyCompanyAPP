<% const user = currentUser; %>
<% const isAdmin = user && (user.role === 'ADMIN' || user.role === 'SUPER_ADMIN'); %>
<% const isSuper = user && user.role === 'SUPER_ADMIN'; %>
<% const roleLabel = user ? (user.role === 'SUPER_ADMIN' ? t('roleSuper') : user.role === 'ADMIN' ? t('roleAdmin') : t('workersTitle')) : ''; %>
<header class="app-header sticky top-0 z-50 border-b border-slate-200/80 bg-white/95 backdrop-blur shadow-sm">
  <div class="mx-auto flex w-full max-w-6xl flex-wrap items-center justify-between gap-4 px-4 py-3">
    <div class="flex items-center gap-3">
      <a class="flex items-center gap-3" href="/">
        <div class="flex h-10 w-10 items-center justify-center overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
          <% if (logoPath) { %>
            <img src="<%= logoPath %>" alt="logo" class="h-10 w-10 object-contain" />
          <% } else { %>
            <span class="text-sm font-bold text-aqua-700">A</span>
          <% } %>
        </div>
        <div>
          <% if (brandWordmarkPath) { %>
            <img src="<%= brandWordmarkPath %>" alt="AQUA MSK" class="h-6 w-auto object-contain" />
          <% } else { %>
            <p class="text-lg font-semibold">AQUA MSK</p>
          <% } %>
          <p class="text-xs text-slate-500"><%= t('brandTagline') %></p>
        </div>
      </a>
      <% if (isSuper) { %>
        <details class="relative">
          <summary class="btn-outline text-xs"><%= t('editBranding') %></summary>
          <div class="absolute left-0 mt-2 w-72 card p-4 shadow-lg">
            <p class="text-xs font-semibold text-slate-600"><%= t('logoImageTitle') %></p>
            <form method="post" action="/admin/logo" enctype="multipart/form-data" class="mt-2 space-y-2">
              <input class="input h-9" type="file" name="logo_file" accept="image/*" required />
              <button class="btn-outline w-full" type="submit"><%= t('uploadLogo') %></button>
            </form>
            <% if (logoPath) { %>
              <form method="post" action="/admin/logo/delete" class="mt-2">
                <button class="btn-danger w-full" type="submit"><%= t('deleteLogo') %></button>
              </form>
            <% } %>
            <div class="mt-4 border-t border-slate-200 pt-3">
              <p class="text-xs font-semibold text-slate-600"><%= t('brandWordmarkTitle') %></p>
              <form method="post" action="/admin/brand-image" enctype="multipart/form-data" class="mt-2 space-y-2">
                <input class="input h-9" type="file" name="brand_file" accept="image/*" required />
                <button class="btn-outline w-full" type="submit"><%= t('uploadBrandImage') %></button>
              </form>
              <% if (brandWordmarkPath) { %>
                <form method="post" action="/admin/brand-image/delete" class="mt-2">
                  <button class="btn-danger w-full" type="submit"><%= t('deleteBrandImage') %></button>
                </form>
              <% } %>
            </div>
          </div>
        </details>
      <% } %>
    </div>

    <div class="flex items-center gap-2">
      <% if (user) { %>
        <button id="menuToggle" class="btn-outline" type="button" aria-haspopup="true" aria-expanded="false">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <span class="ml-2 text-xs font-semibold"><%= t('menu') %></span>
        </button>
      <% } %>
      <div class="hidden text-right sm:block">
        <p class="text-sm font-semibold"><%= user ? user.full_name : '' %></p>
        <p class="text-xs text-slate-500"><%= roleLabel %></p>
      </div>
      <form method="post" action="/logout" onsubmit="return confirm('<%= t('logoutConfirm') %>');">
        <button class="btn-outline" type="submit">Logout</button>
      </form>
    </div>
  </div>
</header>

