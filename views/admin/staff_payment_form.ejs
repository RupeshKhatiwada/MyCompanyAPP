<%- include('../partials/shell-start', { title }) %>
<section class="py-8">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-3xl font-semibold"><%= t('editSalaryPaymentTitle') %></h1>
      <p class="text-slate-600"><%= staff.full_name %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a class="btn-outline" href="<%= basePath %>/<%= staff.id %>"><%= t('back') %></a>
    </div>
  </div>

  <div class="mt-6 card p-6 max-w-3xl">
    <form class="grid gap-3 sm:grid-cols-2" method="post" action="<%= basePath %>/payments/<%= payment.id %>">
      <div>
        <label class="label"><%= t('paymentType') %></label>
        <select class="input" name="payment_type" required>
          <option value="SALARY" <%= payment.payment_type === 'SALARY' ? 'selected' : '' %>><%= t('salaryPaid') %></option>
          <option value="ADVANCE" <%= payment.payment_type === 'ADVANCE' ? 'selected' : '' %>><%= t('advancePaid') %></option>
        </select>
      </div>
      <div>
        <label class="label"><%= t('amount') %></label>
        <input class="input" type="number" step="0.01" min="0" name="amount" value="<%= payment.amount %>" required />
      </div>
      <div>
        <label class="label"><%= t('date') %></label>
        <input class="input" type="date" name="payment_date" value="<%= payment.payment_date %>" required />
      </div>
      <div>
        <label class="label"><%= t('note') %></label>
        <input class="input" type="text" name="note" value="<%= payment.note || '' %>" />
      </div>
      <div class="sm:col-span-2 flex flex-wrap gap-2">
        <button class="btn-primary" type="submit"><%= t('save') %></button>
        <button class="btn-outline" type="submit" name="print" value="1"><%= t('saveAndPrint') %></button>
      </div>
    </form>
  </div>
</section>
<%- include('../partials/shell-end') %>
