<%- include('../partials/shell-start', { title }) %>
<section class="py-8">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-3xl font-semibold"><%= t('profitSummaryTitle') %></h1>
      <p class="text-slate-600"><%= t('profitSummarySubtitle') %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a class="btn-outline" href="/admin/reports/profit/print?from=<%= from %>&to=<%= to %>" target="_blank"><%= t('print') %></a>
    </div>
  </div>

  <form class="mt-4 flex flex-wrap items-end gap-3" method="get" action="/admin/reports/profit">
    <div>
      <label class="label"><%= t('from') %></label>
      <input class="input" type="date" name="from" value="<%= from %>" />
    </div>
    <div>
      <label class="label"><%= t('to') %></label>
      <input class="input" type="date" name="to" value="<%= to %>" />
    </div>
    <button class="btn-outline" type="submit"><%= t('filter') %></button>
  </form>

  <div class="mt-6 grid gap-3 text-sm sm:grid-cols-3">
    <div class="card p-4">
      <p class="text-slate-500"><%= t('totalSales') %></p>
      <p class="text-lg font-semibold"><%= summary.total_sales %></p>
    </div>
    <div class="card p-4">
      <p class="text-slate-500"><%= t('leakageCost') %></p>
      <p class="text-lg font-semibold"><%= summary.leakage_cost %></p>
    </div>
    <div class="card p-4">
      <p class="text-slate-500"><%= t('profit') %></p>
      <p class="text-lg font-semibold"><%= summary.profit %></p>
    </div>
  </div>

  <div class="mt-6 card overflow-hidden">
    <div class="overflow-x-auto">
      <table class="table-base">
        <thead class="table-head">
          <tr>
            <th class="px-4 py-3"><%= t('date') %></th>
            <th class="px-4 py-3"><%= t('totalSales') %></th>
            <th class="px-4 py-3"><%= t('leakageJars') %></th>
            <th class="px-4 py-3"><%= t('leakageCost') %></th>
            <th class="px-4 py-3"><%= t('profit') %></th>
          </tr>
        </thead>
        <tbody>
          <% if (rows.length === 0) { %>
            <tr>
              <td class="px-4 py-4 text-slate-500" colspan="5"><%= t('noData') %></td>
            </tr>
          <% } %>
          <% rows.forEach((row) => { %>
            <% const leakageCost = Number(row.leakage_cost || 0); %>
            <tr class="table-row">
              <td class="px-4 py-3"><%= row.export_date %></td>
              <td class="px-4 py-3"><%= row.total_amount %></td>
              <td class="px-4 py-3"><%= row.leakage_jars %></td>
              <td class="px-4 py-3"><%= leakageCost %></td>
              <td class="px-4 py-3"><%= Number(row.total_amount || 0) - leakageCost %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>
<%- include('../partials/shell-end') %>
