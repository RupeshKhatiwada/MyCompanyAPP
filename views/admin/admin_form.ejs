<%- include('../partials/shell-start', { title }) %>
<section class="py-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-semibold"><%= t('addAdminTitle') %></h1>
      <p class="text-slate-600"><%= t('adminFormSubtitle') %></p>
    </div>
    <a class="btn-outline" href="/admin/admins"><%= t('back') %></a>
  </div>

  <div class="mt-6 card p-6">
    <% if (error) { %>
      <div class="mb-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700"><%= error %></div>
    <% } %>
    <form method="post" action="/admin/admins" class="space-y-4">
      <div>
        <label class="label"><%= t('fullName') %></label>
        <input class="input" type="text" name="full_name" required />
      </div>
      <div>
        <label class="label"><%= t('username') %></label>
        <input class="input" type="text" name="username" required />
      </div>
      <div>
        <label class="label"><%= t('phone') %></label>
        <input class="input" type="text" name="phone" />
      </div>
      <div>
        <label class="label"><%= t('password') %></label>
        <input class="input" type="password" name="password" required />
      </div>
      <div>
        <label class="label"><%= t('role') %></label>
        <select class="input" name="role">
          <option value="ADMIN"><%= t('roleAdmin') %></option>
          <option value="SUPER_ADMIN"><%= t('roleSuper') %></option>
        </select>
      </div>
      <button class="btn-primary" type="submit"><%= t('save') %></button>
    </form>
  </div>
</section>
<%- include('../partials/shell-end') %>
