<%- include('../partials/shell-start', { title }) %>
<% const routeBase = typeof vehicleRouteBase === 'string' && vehicleRouteBase ? vehicleRouteBase : '/admin/vehicles'; %>
<% const showInactive = Number(includeInactive || 0) === 1; %>
<section class="py-8">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-3xl font-semibold"><%= t('vehicles') %></h1>
      <p class="text-slate-600"><%= t('manageVehicles') %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a class="btn-outline" href="<%= routeBase %>?include_inactive=<%= showInactive ? '0' : '1' %>">
        <%= showInactive ? t('hideArchived') : t('showArchived') %>
      </a>
      <a class="btn-primary" href="<%= routeBase %>/new"><%= t('addVehicle') %></a>
    </div>
  </div>

  <div class="mt-6 card overflow-hidden">
    <% if (success) { %>
      <div class="mx-4 mt-4 rounded-lg bg-emerald-50 px-4 py-3 text-sm text-emerald-700"><%= success %></div>
    <% } %>
    <div class="overflow-x-auto">
      <table class="table-base">
        <thead class="table-head">
          <tr>
            <th class="px-4 py-3"><%= t('photo') %></th>
            <th class="px-4 py-3"><%= t('vehicleNumber') %></th>
            <th class="px-4 py-3"><%= t('owner') %></th>
            <th class="px-4 py-3"><%= t('phone') %></th>
            <th class="px-4 py-3"><%= t('vehicleType') %></th>
            <th class="px-4 py-3"><%= t('status') %></th>
            <th class="px-4 py-3 text-right"><%= t('actions') %></th>
          </tr>
        </thead>
        <tbody>
          <% if (vehicles.length === 0) { %>
            <tr>
              <td class="px-4 py-4 text-slate-500" colspan="7"><%= t('noVehicles') %></td>
            </tr>
          <% } %>
          <% vehicles.forEach((vehicle) => { %>
            <tr class="table-row">
              <td class="px-4 py-3">
                <% if (vehicle.profile_pic_path) { %>
                  <img src="<%= vehicle.profile_pic_path %>" alt="vehicle" class="h-10 w-10 rounded-full object-cover" />
                <% } else { %>
                  <div class="h-10 w-10 rounded-full bg-slate-200"></div>
                <% } %>
              </td>
              <td class="px-4 py-3 font-medium"><%= vehicle.vehicle_number %></td>
              <td class="px-4 py-3"><%= vehicle.owner_name %></td>
              <td class="px-4 py-3"><%= vehicle.phone || '-' %></td>
              <td class="px-4 py-3"><%= vehicle.is_company ? t('companyVehicle') : t('partnerVehicle') %></td>
              <td class="px-4 py-3">
                <% if (Number(vehicle.is_active || 1) === 1) { %>
                  <span class="badge bg-emerald-100 text-emerald-700"><%= t('active') %></span>
                <% } else { %>
                  <span class="badge bg-slate-100 text-slate-700"><%= t('inactive') %></span>
                <% } %>
              </td>
              <td class="px-4 py-3 text-right">
                <div class="flex justify-end gap-2">
                  <a class="btn-outline" href="<%= routeBase %>/<%= vehicle.id %>/edit"><%= t('edit') %></a>
                  <% if (Number(vehicle.is_active || 1) === 1) { %>
                    <form method="post" action="<%= routeBase %>/<%= vehicle.id %>/archive" onsubmit="return confirm('<%= t('archiveVehicleConfirm') %>');">
                      <button class="btn-danger" type="submit"><%= t('archive') %></button>
                    </form>
                  <% } else { %>
                    <form method="post" action="<%= routeBase %>/<%= vehicle.id %>/activate" onsubmit="return confirm('<%= t('activateVehicleConfirm') %>');">
                      <button class="btn-primary" type="submit"><%= t('activate') %></button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>
<%- include('../partials/shell-end') %>
