<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= t('returnsReportTitle') %> | AQUA MSK</title>
  <link rel="stylesheet" href="/css/styles.css?v=<%= assetVersion %>" />
  <style>
    @media print { .print-hidden { display: none !important; } }
  </style>
</head>
<body class="bg-white text-slate-900">
  <div class="mx-auto max-w-4xl p-6">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div class="flex-1">
        <%- include('../partials/print-brand', { subtitle: t('returnsReportTitle') }) %>
        <p class="mt-2 text-sm text-slate-600"><%= t('date') %>: <%= date %></p>
      </div>
      <button class="btn-primary print-hidden" onclick="window.print()"><%= t('print') %></button>
    </div>

    <div class="mt-6 overflow-hidden rounded-2xl border border-slate-200">
      <table class="table-base">
        <thead class="table-head">
          <tr>
            <th class="px-4 py-3"><%= t('vehicle') %></th>
            <th class="px-4 py-3"><%= t('returnJars') %></th>
            <th class="px-4 py-3"><%= t('leakageJars') %></th>
            <th class="px-4 py-3"><%= t('returnBottleCases') %></th>
          </tr>
        </thead>
        <tbody>
          <% if (rows.length === 0) { %>
            <tr>
              <td class="px-4 py-4 text-slate-500" colspan="4"><%= t('noData') %></td>
            </tr>
          <% } %>
          <% rows.forEach((row) => { %>
            <tr class="table-row">
              <td class="px-4 py-3 font-medium"><%= row.vehicle_number %> - <%= row.owner_name %></td>
              <td class="px-4 py-3"><%= row.return_jars %></td>
              <td class="px-4 py-3"><%= row.leakage_jars %></td>
              <td class="px-4 py-3"><%= row.return_bottles %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="mt-6 grid gap-3 text-sm sm:grid-cols-3">
      <div class="card p-4">
        <p class="text-slate-500"><%= t('totalReturnJars') %></p>
        <p class="text-lg font-semibold"><%= totals.return_jars %></p>
      </div>
      <div class="card p-4">
        <p class="text-slate-500"><%= t('totalLeakageJars') %></p>
        <p class="text-lg font-semibold"><%= totals.leakage_jars %></p>
      </div>
      <div class="card p-4">
        <p class="text-slate-500"><%= t('totalReturnBottleCases') %></p>
        <p class="text-lg font-semibold"><%= totals.return_bottles %></p>
      </div>
    </div>
  </div>
</body>
</html>
