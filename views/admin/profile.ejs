<%- include('../partials/shell-start', { title }) %>
<% const actionPath = typeof profileAction !== 'undefined' ? profileAction : '/admin/profile'; %>
<% const attendanceActionPath = typeof attendanceAction !== 'undefined' ? attendanceAction : '/admin/profile/attendance'; %>
<section class="py-8">
  <div class="page-header">
    <h1 class="text-3xl font-semibold"><%= t('profileTitle') %></h1>
    <p class="mt-2 text-slate-600"><%= t('profileSubtitle') %></p>
  </div>

  <div class="mt-6 card p-6">
    <% if (error) { %>
      <div class="mb-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="mb-4 rounded-lg bg-emerald-50 px-4 py-3 text-sm text-emerald-700"><%= success %></div>
    <% } %>
    <% if (user.role === 'WORKER') { %>
      <div class="mb-4 rounded-xl border border-slate-200 bg-slate-50 p-4">
        <p class="label mb-2"><%= t('profilePhotoLabel') %></p>
        <div class="flex items-center gap-3">
          <% if (user.photo_path) { %>
            <img src="<%= user.photo_path %>" alt="<%= t('profilePhotoLabel') %>" class="h-16 w-16 rounded-full border border-slate-200 object-cover" />
          <% } else { %>
            <div class="flex h-16 w-16 items-center justify-center rounded-full border border-dashed border-slate-300 bg-white text-xs text-slate-500">N/A</div>
          <% } %>
          <div>
            <p class="text-xs text-slate-600"><%= t('workerPhotoManagedByAdmin') %></p>
            <% if (!user.photo_path) { %>
              <p class="mt-1 text-xs text-slate-500"><%= t('noProfilePhoto') %></p>
            <% } %>
          </div>
        </div>
      </div>
    <% } %>
    <form method="post" action="<%= actionPath %>" class="space-y-4">
      <div>
        <label class="label"><%= t('fullName') %></label>
        <input class="input" type="text" name="full_name" value="<%= user.full_name %>" required />
      </div>
      <div>
        <label class="label"><%= t('username') %></label>
        <input class="input" type="text" value="<%= user.username %>" disabled />
      </div>
      <div>
        <label class="label"><%= t('phone') %></label>
        <input class="input" type="text" name="phone" value="<%= user.phone || '' %>" />
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        <div>
          <label class="label"><%= t('currentPassword') %></label>
          <input class="input" type="password" name="current_password" />
        </div>
        <div>
          <label class="label"><%= t('newPassword') %></label>
          <input class="input" type="password" name="new_password" />
        </div>
      </div>
      <button class="btn-primary" type="submit"><%= t('updateProfile') %></button>
    </form>
  </div>

  <div class="mt-6 card p-6">
    <h2 class="text-lg font-semibold"><%= t('preferencesTitle') %></h2>
    <p class="mt-2 text-sm text-slate-600"><%= t('preferencesSubtitle') %></p>
    <div class="mt-4 grid gap-4 md:grid-cols-2">
      <div class="card p-4">
        <p class="text-sm font-semibold text-slate-700"><%= t('languageSettings') %></p>
        <div class="mt-3 flex items-center gap-2">
          <a class="btn-outline <%= lang === 'en' ? 'bg-slate-100' : '' %>" href="/lang/en">EN</a>
          <a class="btn-outline <%= lang === 'ne' ? 'bg-slate-100' : '' %>" href="/lang/ne">ने</a>
        </div>
      </div>
      <div class="card p-4">
        <p class="text-sm font-semibold text-slate-700"><%= t('fontSize') %></p>
        <div class="mt-3 flex items-center gap-2">
          <button class="btn-outline font-size-toggle" type="button" data-font-size="sm" title="<%= t('fontSmall') %>">A-</button>
          <button class="btn-outline font-size-toggle" type="button" data-font-size="md" title="<%= t('fontMedium') %>">A</button>
          <button class="btn-outline font-size-toggle" type="button" data-font-size="lg" title="<%= t('fontLarge') %>">A+</button>
        </div>
      </div>
    </div>
  </div>

  <% if (typeof attendanceDate !== 'undefined') { %>
    <div class="mt-6 card p-6">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <h2 class="text-lg font-semibold"><%= t('attendanceTitle') %></h2>
          <p class="mt-1 text-sm text-slate-600"><%= t('attendanceSubtitle') %></p>
        </div>
        <p class="text-xs text-slate-500"><%= t('attendanceDate') %>: <%= attendanceDate %></p>
      </div>
      <% if (attendanceSaved) { %>
        <div class="mt-4 rounded-lg bg-emerald-50 px-4 py-3 text-sm text-emerald-700"><%= attendanceSaved %></div>
      <% } %>
      <form class="mt-4 flex flex-wrap items-center gap-4" method="post" action="<%= attendanceActionPath %>">
        <input type="hidden" name="attendance_date" value="<%= attendanceDate %>" />
        <% const selectedStatus = attendanceStatus || 'ABSENT'; %>
        <label class="flex items-center gap-2 text-sm">
          <input type="radio" name="status" value="PRESENT" <%= selectedStatus === 'PRESENT' ? 'checked' : '' %> />
          <span><%= t('present') %></span>
        </label>
        <label class="flex items-center gap-2 text-sm">
          <input type="radio" name="status" value="ABSENT" <%= selectedStatus === 'ABSENT' ? 'checked' : '' %> />
          <span><%= t('absent') %></span>
        </label>
        <button class="btn-primary" type="submit"><%= t('save') %></button>
      </form>

      <div class="mt-4">
        <p class="text-sm font-semibold text-slate-700"><%= t('attendanceHistory') %></p>
        <% if (attendanceHistory && attendanceHistory.length) { %>
          <div class="mt-3 overflow-x-auto">
            <table class="table-base">
              <thead class="table-head">
                <tr>
                  <th class="px-4 py-3"><%= t('date') %></th>
                  <th class="px-4 py-3"><%= t('status') %></th>
                  <th class="px-4 py-3"><%= t('recordedBy') %></th>
                </tr>
              </thead>
              <tbody>
                <% attendanceHistory.forEach((row) => { %>
                  <tr class="table-row">
                    <td class="px-4 py-3"><%= row.attendance_date %></td>
                    <td class="px-4 py-3"><%= row.status === 'PRESENT' ? t('present') : t('absent') %></td>
                    <td class="px-4 py-3"><%= row.recorded_by || '-' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="mt-2 text-sm text-slate-500"><%= t('noAttendanceHistory') %></p>
        <% } %>
      </div>
    </div>
  <% } %>
</section>
<%- include('../partials/shell-end') %>
