<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= t('profitSummaryTitle') %> | AQUA MSK</title>
  <link rel="stylesheet" href="/css/styles.css?v=<%= assetVersion %>" />
  <style>
    @media print { .print-hidden { display: none !important; } }
  </style>
</head>
<body class="bg-white text-slate-900">
  <div class="mx-auto max-w-5xl p-6">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div class="flex-1">
        <%- include('../partials/print-brand', { subtitle: t('profitSummaryTitle') }) %>
        <p class="mt-2 text-sm text-slate-600"><%= t('from') %>: <%= from %> | <%= t('to') %>: <%= to %></p>
      </div>
      <button class="btn-primary print-hidden" onclick="window.print()"><%= t('print') %></button>
    </div>

    <div class="mt-6 grid gap-3 text-sm sm:grid-cols-3">
      <div class="card p-4">
        <p class="text-slate-500"><%= t('totalSales') %></p>
        <p class="text-lg font-semibold"><%= summary.total_sales %></p>
      </div>
      <div class="card p-4">
        <p class="text-slate-500"><%= t('leakageCost') %></p>
        <p class="text-lg font-semibold"><%= summary.leakage_cost %></p>
      </div>
      <div class="card p-4">
        <p class="text-slate-500"><%= t('profit') %></p>
        <p class="text-lg font-semibold"><%= summary.profit %></p>
      </div>
    </div>

    <div class="mt-6 overflow-hidden rounded-2xl border border-slate-200">
      <table class="table-base">
        <thead class="table-head">
          <tr>
            <th class="px-4 py-3"><%= t('date') %></th>
            <th class="px-4 py-3"><%= t('totalSales') %></th>
            <th class="px-4 py-3"><%= t('leakageJars') %></th>
            <th class="px-4 py-3"><%= t('leakageCost') %></th>
            <th class="px-4 py-3"><%= t('profit') %></th>
          </tr>
        </thead>
        <tbody>
          <% if (rows.length === 0) { %>
            <tr>
              <td class="px-4 py-4 text-slate-500" colspan="5"><%= t('noData') %></td>
            </tr>
          <% } %>
          <% rows.forEach((row) => { %>
            <% const leakageCost = Number(row.leakage_cost || 0); %>
            <tr class="table-row">
              <td class="px-4 py-3"><%= row.export_date %></td>
              <td class="px-4 py-3"><%= row.total_amount %></td>
              <td class="px-4 py-3"><%= row.leakage_jars %></td>
              <td class="px-4 py-3"><%= leakageCost %></td>
              <td class="px-4 py-3"><%= Number(row.total_amount || 0) - leakageCost %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
