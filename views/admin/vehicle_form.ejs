<%- include('../partials/shell-start', { title }) %>
<% const routeBase = typeof vehicleRouteBase === 'string' && vehicleRouteBase ? vehicleRouteBase : '/admin/vehicles'; %>
<section class="py-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-semibold"><%= vehicle ? t('editVehicleTitle') : t('addVehicleTitle') %></h1>
      <p class="text-slate-600"><%= t('vehicleFormSubtitle') %></p>
    </div>
    <a class="btn-outline" href="<%= routeBase %>"><%= t('back') %></a>
  </div>

  <div class="mt-6 card p-6">
    <% if (error) { %>
      <div class="mb-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700"><%= error %></div>
    <% } %>
    <form method="post" action="<%= vehicle ? routeBase + '/' + vehicle.id : routeBase %>" enctype="multipart/form-data" class="space-y-4">
      <div>
        <label class="label"><%= t('vehicleNumber') %></label>
        <input class="input" type="text" name="vehicle_number" value="<%= vehicle ? vehicle.vehicle_number : '' %>" required />
      </div>
      <div>
        <label class="label"><%= t('ownerName') %></label>
        <input class="input" type="text" name="owner_name" value="<%= vehicle ? vehicle.owner_name : '' %>" required />
      </div>
      <div>
        <label class="label"><%= t('phone') %></label>
        <input class="input" type="text" name="phone" value="<%= vehicle ? vehicle.phone || '' : '' %>" />
      </div>
      <div class="flex items-center gap-2">
        <input class="h-4 w-4" type="checkbox" id="is_company" name="is_company" <%= vehicle && vehicle.is_company ? 'checked' : '' %> />
        <label class="label !mb-0" for="is_company"><%= t('companyVehicle') %></label>
      </div>
      <div>
        <label class="label"><%= t('profilePhoto') %></label>
        <input class="input" type="file" name="profile_pic" accept="image/*" />
        <% if (vehicle && vehicle.profile_pic_path) { %>
          <img src="<%= vehicle.profile_pic_path %>" alt="profile" class="mt-3 h-16 w-16 rounded-full object-cover" />
        <% } %>
      </div>
      <button class="btn-primary" type="submit"><%= t('save') %></button>
    </form>
  </div>
</section>
<%- include('../partials/shell-end') %>
