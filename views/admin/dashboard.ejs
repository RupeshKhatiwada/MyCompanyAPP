<%- include('../partials/shell-start', { title }) %>
<section class="py-8">
  <div class="page-header flex flex-wrap items-center justify-between gap-6">
    <div>
      <h1 class="text-3xl font-semibold"><%= t('adminDashboard') %></h1>
      <p class="mt-2 text-slate-600"><%= t('welcomeLine') %></p>
    </div>
    <div class="flex items-center gap-2">
      <a class="btn-outline" href="/admin/alerts"><%= t('alertCenterTitle') %></a>
      <a class="btn-outline" href="/records/history"><%= t('activityLogTitle') %></a>
    </div>
  </div>

  <div class="mt-4 card p-4">
    <form class="flex flex-wrap items-end gap-3" method="get" action="/search">
      <div class="min-w-[220px] flex-1">
        <label class="label"><%= t('search') %></label>
        <input class="input" type="text" name="q" placeholder="<%= t('searchGlobal') %>" />
      </div>
      <button class="btn-primary" type="submit"><%= t('search') %></button>
    </form>
  </div>

  <% if (stats.backupOverdue) { %>
    <div class="mt-6 card border border-amber-200 bg-amber-50 p-5">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <p class="text-sm font-semibold text-amber-800"><%= t('backupReminderTitle') %></p>
          <p class="text-sm text-amber-700"><%= t('backupReminderMessagePrefix') %> <%= stats.backupReminderText %>. <%= t('backupReminderMessageSuffix') %></p>
        </div>
        <div class="flex flex-wrap gap-2">
          <a class="btn-primary" href="/admin/backup"><%= t('backupNow') %></a>
          <a class="btn-outline" href="/admin/settings"><%= t('backupSettings') %></a>
        </div>
      </div>
    </div>
  <% } %>

  <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-5">
    <div class="card border border-red-200/70 bg-gradient-to-br from-white via-red-50 to-white p-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-red-700"><%= t('totalVehicles') %></p>
      <p class="mt-2 text-3xl font-semibold text-slate-900"><%= stats.vehicleCount %></p>
    </div>
    <div class="card border border-red-200/70 bg-gradient-to-br from-white via-red-50 to-white p-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-red-700"><%= t('totalWorkers') %></p>
      <p class="mt-2 text-3xl font-semibold text-slate-900"><%= stats.workerCount %></p>
    </div>
    <div class="card border border-red-200/70 bg-gradient-to-br from-white via-red-50 to-white p-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-red-700"><%= t('totalStaffs') %></p>
      <p class="mt-2 text-3xl font-semibold text-slate-900"><%= stats.staffCount %></p>
    </div>
    <div class="card border border-emerald-200/80 bg-gradient-to-br from-white via-emerald-50 to-white p-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-emerald-700"><%= t('monthPaid') %></p>
      <p class="mt-2 text-3xl font-semibold text-slate-900"><%= stats.monthCombined.paid %></p>
      <p class="mt-2 text-xs text-slate-600">
        <%= t('exportsTitle') %>: <span class="font-semibold"><%= stats.monthExport.paid %></span> •
        <%= t('customerPayments') %>: <span class="font-semibold"><%= stats.monthCustomer.paid %></span>
      </p>
    </div>
    <div class="card border border-amber-200/80 bg-gradient-to-br from-white via-amber-50 to-white p-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-amber-700"><%= t('monthCredit') %></p>
      <p class="mt-2 text-3xl font-semibold text-slate-900"><%= stats.monthCombined.credit %></p>
      <p class="mt-2 text-xs text-slate-600">
        <%= t('exportsOutstanding') %>: <span class="font-semibold"><%= stats.monthExport.credit %></span> •
        <%= t('customerOutstanding') %>: <span class="font-semibold"><%= stats.monthCustomer.credit %></span>
      </p>
    </div>
  </div>

  <div class="mt-4 grid gap-4 md:grid-cols-2">
    <div class="card p-5">
      <p class="text-sm text-slate-500"><%= t('customerCumulativeCreditsTitle') %></p>
      <p class="mt-2 text-2xl font-semibold text-amber-700"><%= stats.outstandingCustomerCredit %></p>
    </div>
    <div class="card p-5">
      <p class="text-sm text-slate-500"><%= t('vehicleCumulativeCreditsTitle') %></p>
      <p class="mt-2 text-2xl font-semibold text-amber-700"><%= stats.outstandingVehicleCredit %></p>
    </div>
  </div>

  <div class="mt-8 grid gap-4 md:grid-cols-2">
    <div class="card p-6">
      <h2 class="text-lg font-semibold"><%= t('quickActions') %></h2>
      <div class="mt-4 flex flex-wrap gap-2">
        <a class="btn-primary" href="/admin/vehicles/new"><%= t('addVehicle') %></a>
        <a class="btn-outline" href="/records/exports/new"><%= t('addExport') %></a>
        <a class="btn-outline" href="/records/credits/new"><%= t('addCredit') %></a>
        <a class="btn-outline" href="/records/water-tests"><%= t('waterTestsTitle') %></a>
        <a class="btn-outline" href="/search"><%= t('search') %></a>
        <a class="btn-outline" href="/records/imports"><%= t('importsTitle') %></a>
      </div>
    </div>
    <div class="card p-6">
      <h2 class="text-lg font-semibold"><%= t('reports') %></h2>
      <p class="mt-2 text-sm text-slate-600"><%= t('printExportSales') %></p>
      <div class="mt-3">
        <% const backupText = stats.lastBackupAt ? new Date(stats.lastBackupAt).toLocaleString() : t('backupNever'); %>
        <span class="pill"><%= t('lastBackup') %>: <%= backupText %></span>
      </div>
      <div class="mt-4 flex flex-wrap gap-2">
        <a class="btn-outline" href="/admin/reports/summary"><%= t('summaryChart') %></a>
        <a class="btn-outline" href="/admin/reports/sales"><%= t('salesReport') %></a>
        <a class="btn-outline" href="/admin/backup"><%= t('backupDatabase') %></a>
      </div>
    </div>
  </div>

  <div class="mt-8 grid gap-4 lg:grid-cols-2">
    <div class="card p-6">
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-semibold"><%= t('topOutstandingCredits') %></h2>
        <a class="btn-outline" href="/records/credits"><%= t('viewAllCredits') %></a>
      </div>
      <div class="mt-4 overflow-x-auto">
        <table class="table-base text-sm">
          <thead class="table-head">
            <tr>
              <th class="px-4 py-3"><%= t('vehicleNumber') %></th>
              <th class="px-4 py-3"><%= t('customerName') %></th>
              <th class="px-4 py-3"><%= t('remainingAmount') %></th>
              <th class="px-4 py-3"><%= t('date') %></th>
            </tr>
          </thead>
          <tbody>
            <% if (!topCredits || topCredits.length === 0) { %>
              <tr>
                <td class="px-4 py-4 text-slate-500" colspan="4"><%= t('noCredits') %></td>
              </tr>
            <% } %>
            <% topCredits.forEach((row) => { %>
              <tr class="table-row">
                <td class="px-4 py-3"><%= row.vehicle_number %></td>
                <td class="px-4 py-3"><%= row.customer_name %></td>
                <td class="px-4 py-3"><%= row.remaining_amount %></td>
                <td class="px-4 py-3"><%= row.credit_date %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <div class="card p-6">
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-semibold"><%= t('recentActivityTitle') %></h2>
        <a class="btn-outline" href="/admin/activity"><%= t('activityLogTitle') %></a>
      </div>
      <div class="mt-4 overflow-hidden rounded-2xl border border-slate-200">
        <div class="overflow-x-auto">
          <table class="table-base text-sm">
            <thead class="table-head">
              <tr>
                <th class="px-4 py-3"><%= t('date') %></th>
                <th class="px-4 py-3"><%= t('user') %></th>
                <th class="px-4 py-3"><%= t('action') %></th>
                <th class="px-4 py-3"><%= t('entity') %></th>
                <th class="px-4 py-3"><%= t('details') %></th>
              </tr>
            </thead>
            <tbody>
              <% if (!recentActivity || recentActivity.length === 0) { %>
                <tr>
                  <td class="px-4 py-4 text-slate-500" colspan="5"><%= t('noActivity') %></td>
                </tr>
              <% } %>
              <% recentActivity.forEach((row) => { %>
                <tr class="table-row">
                  <td class="px-4 py-3"><%= row.created_at %></td>
                  <td class="px-4 py-3 font-medium"><%= row.user_name || '-' %></td>
                  <td class="px-4 py-3"><%= row.actionLabel || row.action %></td>
                  <td class="px-4 py-3"><%= row.entityLabel || row.entity_type %></td>
                  <td class="px-4 py-3"><%= row.detailLabel || row.details || '-' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</section>
<%- include('../partials/shell-end') %>
