<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= t('staffScorecardTitle') %> | AQUA MSK</title>
  <link rel="stylesheet" href="/css/styles.css?v=<%= assetVersion %>" />
  <style>
    @media print { .print-hidden { display: none !important; } }
  </style>
</head>
<body class="bg-white text-slate-900">
  <div class="mx-auto max-w-5xl p-6">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div class="flex-1">
        <%- include('../partials/print-brand', { subtitle: t('staffScorecardTitle') }) %>
        <p class="mt-2 text-sm text-slate-600"><%= t('from') %>: <%= from %> | <%= t('to') %>: <%= to %></p>
      </div>
      <button class="btn-primary print-hidden" onclick="window.print()"><%= t('print') %></button>
    </div>

    <div class="mt-6 overflow-hidden rounded-2xl border border-slate-200">
      <table class="table-base">
        <thead class="table-head">
          <tr>
            <th class="px-4 py-3"><%= t('name') %></th>
            <th class="px-4 py-3"><%= t('role') %></th>
            <th class="px-4 py-3"><%= t('exportCount') %></th>
            <th class="px-4 py-3"><%= t('totalExportAmount') %></th>
            <th class="px-4 py-3"><%= t('creditCount') %></th>
            <th class="px-4 py-3"><%= t('creditAmount') %></th>
            <th class="px-4 py-3"><%= t('paymentCount') %></th>
            <th class="px-4 py-3"><%= t('totalPayments') %></th>
          </tr>
        </thead>
        <tbody>
          <% if (rows.length === 0) { %>
            <tr>
              <td class="px-4 py-4 text-slate-500" colspan="8"><%= t('noData') %></td>
            </tr>
          <% } %>
          <% rows.forEach((row) => { %>
            <tr class="table-row">
              <td class="px-4 py-3"><%= row.full_name %></td>
              <td class="px-4 py-3"><%= row.role %></td>
              <td class="px-4 py-3"><%= row.export_count %></td>
              <td class="px-4 py-3"><%= row.export_total %></td>
              <td class="px-4 py-3"><%= row.credit_count %></td>
              <td class="px-4 py-3"><%= row.credit_total %></td>
              <td class="px-4 py-3"><%= row.payment_count %></td>
              <td class="px-4 py-3"><%= row.payment_total %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
