<%- include('../partials/shell-start', { title }) %>
<section class="py-8">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-3xl font-semibold"><%= t('dailyCloseTitle') %></h1>
      <p class="text-slate-600"><%= t('dailyCloseSubtitle') %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a class="btn-outline" href="/admin/reports/daily-close/export?date=<%= date %>"><%= t('exportCsv') %></a>
      <a class="btn-outline" href="/admin/reports/daily-close/print?date=<%= date %>" target="_blank"><%= t('print') %></a>
    </div>
  </div>

  <form class="mt-4 flex flex-wrap items-end gap-3" method="get" action="/admin/reports/daily-close">
    <div>
      <label class="label"><%= t('date') %></label>
      <input class="input" type="date" name="date" value="<%= date %>" />
    </div>
    <button class="btn-outline" type="submit"><%= t('filter') %></button>
  </form>

  <% const netJars = Math.max(0, (summary.jars || 0) - (summary.return_jars || 0) - (summary.leakage_jars || 0)); %>
  <% const netBottles = Math.max(0, (summary.bottles || 0) - (summary.return_bottles || 0)); %>

  <div class="mt-6 grid gap-3 text-sm sm:grid-cols-2 lg:grid-cols-4">
    <div class="card p-4">
      <p class="text-slate-500"><%= t('totalExportAmount') %></p>
      <p class="text-lg font-semibold"><%= summary.total_amount %></p>
    </div>
    <div class="card p-4">
      <p class="text-slate-500"><%= t('paidAmount') %></p>
      <p class="text-lg font-semibold"><%= summary.paid_amount %></p>
    </div>
    <div class="card p-4">
      <p class="text-slate-500"><%= t('remainingAmount') %></p>
      <p class="text-lg font-semibold"><%= summary.remaining_credit %></p>
    </div>
    <div class="card p-4">
      <p class="text-slate-500"><%= t('netJars') %></p>
      <p class="text-lg font-semibold"><%= netJars %></p>
    </div>
    <div class="card p-4">
      <p class="text-slate-500"><%= t('netBottles') %></p>
      <p class="text-lg font-semibold"><%= netBottles %></p>
    </div>
    <div class="card p-4">
      <p class="text-slate-500"><%= t('totalReturnJars') %></p>
      <p class="text-lg font-semibold"><%= summary.return_jars %></p>
    </div>
    <div class="card p-4">
      <p class="text-slate-500"><%= t('totalLeakageJars') %></p>
      <p class="text-lg font-semibold"><%= summary.leakage_jars %></p>
    </div>
    <div class="card p-4">
      <p class="text-slate-500"><%= t('totalReturnBottleCases') %></p>
      <p class="text-lg font-semibold"><%= summary.return_bottles %></p>
    </div>
  </div>

  <div class="mt-6 card overflow-hidden">
    <div class="overflow-x-auto">
      <table class="table-base">
        <thead class="table-head">
          <tr>
            <th class="px-4 py-3"><%= t('vehicle') %></th>
            <th class="px-4 py-3"><%= t('jars') %></th>
            <th class="px-4 py-3"><%= t('returnJars') %></th>
            <th class="px-4 py-3"><%= t('leakageJars') %></th>
            <th class="px-4 py-3"><%= t('netJars') %></th>
            <th class="px-4 py-3"><%= t('bottleCases') %></th>
            <th class="px-4 py-3"><%= t('returnBottleCases') %></th>
            <th class="px-4 py-3"><%= t('netBottles') %></th>
            <th class="px-4 py-3"><%= t('totalExportAmount') %></th>
            <th class="px-4 py-3"><%= t('paidAmount') %></th>
            <th class="px-4 py-3"><%= t('creditAmount') %></th>
            <th class="px-4 py-3"><%= t('recordedBy') %></th>
          </tr>
        </thead>
        <tbody>
          <% if (rows.length === 0) { %>
            <tr>
              <td class="px-4 py-4 text-slate-500" colspan="12"><%= t('noExports') %></td>
            </tr>
          <% } %>
          <% rows.forEach((row) => { %>
            <% const rowNetJars = Math.max(0, (row.jar_count || 0) - (row.return_jar_count || 0) - (row.leakage_jar_count || 0)); %>
            <% const rowNetBottles = Math.max(0, (row.bottle_case_count || 0) - (row.return_bottle_case_count || 0)); %>
            <tr class="table-row">
              <td class="px-4 py-3 font-medium"><%= row.vehicle_number %></td>
              <td class="px-4 py-3"><%= row.jar_count %></td>
              <td class="px-4 py-3"><%= row.return_jar_count %></td>
              <td class="px-4 py-3"><%= row.leakage_jar_count %></td>
              <td class="px-4 py-3"><%= rowNetJars %></td>
              <td class="px-4 py-3"><%= row.bottle_case_count %></td>
              <td class="px-4 py-3"><%= row.return_bottle_case_count %></td>
              <td class="px-4 py-3"><%= rowNetBottles %></td>
              <td class="px-4 py-3"><%= row.total_amount %></td>
              <td class="px-4 py-3"><%= row.paid_amount %></td>
              <td class="px-4 py-3"><%= row.credit_amount %></td>
              <td class="px-4 py-3"><%= row.recorded_by || '-' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>
<%- include('../partials/shell-end') %>
