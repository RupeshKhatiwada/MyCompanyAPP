<%- include('../partials/shell-start', { title }) %>
<section class="py-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-semibold"><%= type ? t('editJarTypeTitle') : t('addJarTypeTitle') %></h1>
      <p class="text-slate-600"><%= t('jarTypeFormSubtitle') %></p>
    </div>
    <a class="btn-outline" href="/admin/jar-types"><%= t('back') %></a>
  </div>

  <div class="mt-6 card p-6">
    <% if (error) { %>
      <div class="mb-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700"><%= error %></div>
    <% } %>
    <form method="post" action="<%= type ? '/admin/jar-types/' + type.id : '/admin/jar-types' %>" class="space-y-4">
      <div>
        <label class="label"><%= t('name') %></label>
        <input class="input" type="text" name="name" value="<%= type ? type.name : '' %>" required />
      </div>
      <div>
        <label class="label"><%= t('defaultQuantity') %></label>
        <input class="input" type="number" name="default_qty" min="0" value="<%= type ? (type.default_qty || 0) : 0 %>" required />
        <p class="mt-1 text-xs text-slate-500"><%= t('defaultJarContainerQtyHint') %></p>
      </div>
      <% if (type) { %>
        <label class="inline-flex items-center gap-2 text-sm">
          <input type="checkbox" name="active" <%= type.active ? 'checked' : '' %> />
          <span><%= t('active') %></span>
        </label>
      <% } %>
      <button class="btn-primary" type="submit"><%= t('save') %></button>
    </form>
  </div>
</section>
<%- include('../partials/shell-end') %>
