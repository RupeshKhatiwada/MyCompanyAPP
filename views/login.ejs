<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | AQUA MSK</title>
  <link rel="stylesheet" href="/css/styles.css?v=<%= assetVersion %>" />
</head>
<body class="text-slate-900">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="grid w-full max-w-4xl gap-6 lg:grid-cols-2">
      <div class="card p-8 flex flex-col justify-between">
        <div>
          <div class="flex items-center gap-3">
            <div class="h-12 w-12 rounded-2xl bg-white/90 ring-1 ring-slate-200 flex items-center justify-center overflow-hidden">
              <% if (logoPath) { %>
                <img src="<%= logoPath %>" alt="logo" class="h-12 w-12 object-contain" />
              <% } else { %>
                <span class="text-xl font-bold text-aqua-700">A</span>
              <% } %>
            </div>
            <div>
              <p class="text-lg font-semibold">AQUA MSK</p>
              <p class="text-xs text-slate-500"><%= t('brandTagline') %></p>
            </div>
          </div>
          <h1 class="mt-6 text-3xl font-semibold"><%= t('loginHeading') %></h1>
          <p class="mt-2 text-sm text-slate-600"><%= t('loginSubtitle') %></p>
        </div>
        <div class="mt-6 rounded-2xl border border-slate-200 bg-white/70 p-4 text-sm text-slate-600">
          <p><%= t('loginIntroLine1') %></p>
          <p class="mt-1"><%= t('loginIntroLine2') %></p>
        </div>
      </div>
      <div class="card w-full p-8">
        <div class="mb-6 text-center">
          <div class="mx-auto mb-3 h-12 w-12 rounded-2xl bg-aqua-600 text-white flex items-center justify-center text-xl font-bold">A</div>
          <h2 class="text-xl font-semibold"><%= t('loginTitle') %></h2>
        </div>
      <% if (created) { %>
        <div class="mb-4 rounded-lg bg-emerald-50 px-4 py-3 text-sm text-emerald-700"><%= t('adminCreated') %></div>
      <% } %>
      <% if (error) { %>
        <div class="mb-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700"><%= error %></div>
      <% } %>
      <form method="post" action="/login" class="space-y-4">
        <div>
          <label class="label">Username</label>
          <input class="input" type="text" name="username" required />
        </div>
        <div>
          <label class="label">Password</label>
          <input class="input" type="password" name="password" required />
        </div>
        <button class="btn-primary w-full" type="submit"><%= t('loginButton') %></button>
      </form>
      <div class="mt-4 text-center">
        <a class="text-sm text-aqua-700 hover:text-aqua-800" href="/recover"><%= t('forgotPassword') %></a>
      </div>
      </div>
    </div>
  </div>
</body>
</html>
