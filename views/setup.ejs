<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | AQUA MSK</title>
  <link rel="stylesheet" href="/css/styles.css?v=<%= assetVersion %>" />
</head>
<body class="bg-gradient-to-br from-red-50 via-white to-aqua-100 text-slate-900">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="card w-full max-w-lg p-8">
      <div class="mb-6 text-center">
        <div class="mx-auto mb-3 h-12 w-12 rounded-2xl bg-aqua-600 text-white flex items-center justify-center text-xl font-bold">A</div>
        <h1 class="text-2xl font-semibold"><%= t('setupHeading') %></h1>
        <p class="text-sm text-slate-500"><%= t('setupSubtitle') %></p>
      </div>
      <% if (error) { %>
        <div class="mb-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700"><%= error %></div>
      <% } %>
      <form method="post" action="/setup" class="space-y-4">
        <div>
          <label class="label"><%= t('fullName') %></label>
          <input class="input" type="text" name="full_name" required />
        </div>
        <div>
          <label class="label"><%= t('username') %></label>
          <input class="input" type="text" name="username" required />
        </div>
        <div>
          <label class="label"><%= t('phoneOptional') %></label>
          <input class="input" type="text" name="phone" />
        </div>
        <div>
          <label class="label"><%= t('password') %></label>
          <input class="input" type="password" name="password" required />
        </div>
        <button class="btn-primary w-full" type="submit"><%= t('createSuperAdmin') %></button>
      </form>
    </div>
  </div>
</body>
</html>
