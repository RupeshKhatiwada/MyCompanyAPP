<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | AQUA MSK</title>
  <link rel="stylesheet" href="/css/styles.css?v=<%= assetVersion %>" />
</head>
<body class="bg-gradient-to-br from-red-50 via-white to-aqua-100 text-slate-900">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="grid w-full max-w-5xl gap-6 lg:grid-cols-2">
      <div class="card p-8">
        <div class="flex items-center gap-3">
          <div class="h-12 w-12 rounded-2xl bg-white/90 ring-1 ring-slate-200 flex items-center justify-center overflow-hidden">
            <% if (logoPath) { %>
              <img src="<%= logoPath %>" alt="logo" class="h-12 w-12 object-contain" />
            <% } else { %>
              <span class="text-xl font-bold text-aqua-700">A</span>
            <% } %>
          </div>
          <div>
            <p class="text-lg font-semibold">AQUA MSK</p>
            <p class="text-xs text-slate-500"><%= t('brandTagline') %></p>
          </div>
        </div>
        <h1 class="mt-6 text-3xl font-semibold"><%= t('recoveryTitle') %></h1>
        <p class="mt-2 text-sm text-slate-600"><%= t('recoveryLoginSubtitle') %></p>
        <div class="mt-6 flex items-center gap-4">
          <picture>
            <source srcset="/images/jar.webp" type="image/webp" />
            <img src="/images/jar.svg" alt="jar" class="h-20 w-20 object-contain" />
          </picture>
          <picture>
            <source srcset="/images/bottle.webp" type="image/webp" />
            <img src="/images/bottle.svg" alt="bottle" class="h-20 w-20 object-contain" />
          </picture>
        </div>
        <p class="mt-6 text-xs text-slate-500"><%= t('recoveryOnlySuper') %></p>
      </div>

      <div class="card w-full p-8 space-y-6">
        <% if (error) { %>
          <div class="rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700"><%= error %></div>
        <% } %>
        <% if (success) { %>
          <div class="rounded-lg bg-emerald-50 px-4 py-3 text-sm text-emerald-700"><%= success %></div>
        <% } %>

        <form method="get" action="/recover" class="space-y-3">
          <div>
            <label class="label"><%= t('selectAdmin') %></label>
            <select class="input" name="user">
              <% (superAdmins || []).forEach((admin) => { %>
                <option value="<%= admin.id %>" <%= selected && String(selected.id) === String(admin.id) ? 'selected' : '' %>>
                  <%= admin.full_name %> (<%= admin.username %>)
                </option>
              <% }) %>
            </select>
          </div>
          <button class="btn-outline" type="submit"><%= t('loadRecovery') %></button>
        </form>

        <div class="rounded-2xl border border-slate-200 p-5">
          <h2 class="text-lg font-semibold"><%= t('recoverWithKey') %></h2>
          <form method="post" action="/recover/key" class="mt-4 space-y-3">
            <input type="hidden" name="user_id" value="<%= selected ? selected.id : '' %>" />
            <div>
              <label class="label"><%= t('recoveryKey') %></label>
              <input class="input" type="text" name="recovery_key" placeholder="<%= t('recoveryKeyPlaceholder') %>" />
            </div>
            <div>
              <label class="label"><%= t('newPassword') %></label>
              <input class="input" type="password" name="new_password" />
            </div>
            <button class="btn-primary w-full" type="submit"><%= t('resetPassword') %></button>
          </form>
        </div>

        <div class="rounded-2xl border border-slate-200 p-5">
          <h2 class="text-lg font-semibold"><%= t('recoverWithQuestions') %></h2>
          <% if (!recovery || !recovery.q1) { %>
            <p class="mt-3 text-sm text-slate-500"><%= t('recoveryQuestionsNotSet') %></p>
          <% } %>
          <% if (recovery && recovery.q1) { %>
            <form method="post" action="/recover/questions" class="mt-4 space-y-3">
              <input type="hidden" name="user_id" value="<%= selected ? selected.id : '' %>" />
              <div>
                <label class="label"><%= recovery.q1 %></label>
                <input class="input" type="text" name="a1" />
              </div>
              <div>
                <label class="label"><%= recovery.q2 %></label>
                <input class="input" type="text" name="a2" />
              </div>
              <div>
                <label class="label"><%= recovery.q3 %></label>
                <input class="input" type="text" name="a3" />
              </div>
              <div>
                <label class="label"><%= t('newPassword') %></label>
                <input class="input" type="password" name="new_password" />
              </div>
              <button class="btn-primary w-full" type="submit"><%= t('resetPassword') %></button>
            </form>
          <% } %>
        </div>

        <a class="btn-outline w-full" href="/login"><%= t('backToLogin') %></a>
      </div>
    </div>
  </div>
</body>
</html>
